#!/usr/bin/env python3
"""pandastack-linear-comment — append-only Linear ledger comments for agent-loop work.

Issue descriptions stay as work orders. This helper writes the running audit log as
Linear comments: branch, commit, PR, checks, PandaStack review artifact, verdict.
It is intentionally append-only. There is no edit/delete path.

Examples:
  pandastack-linear-comment --issue PRO-26 --repo panda850819/pandastack \
    --branch feat/x --commit abc1234 --pr https://github.com/.../pull/1 \
    --checks "tests green" --review-url https://github.com/...#issuecomment-1 \
    --verdict "ready for human review"

  pandastack-linear-comment --issue PRO-26 --body-file /tmp/comment.md
"""
import argparse
import json
import os
import pathlib
import re
import sys
import urllib.error
import urllib.request

LINEAR_URL = "https://api.linear.app/graphql"
SECRETS = pathlib.Path.home() / ".config/pandastack/secrets.env"


def load_key():
    key = os.environ.get("LINEAR_API_KEY")
    if key:
        return key
    if SECRETS.exists():
        for line in SECRETS.read_text(encoding="utf-8").splitlines():
            line = line.strip()
            if not line or line.startswith("#"):
                continue
            if line.startswith("export "):
                line = line[7:]
            m = re.match(r"LINEAR_API_KEY\s*=\s*(.+)\s*$", line)
            if m:
                return m.group(1).strip().strip('"').strip("'")
    sys.exit("error: LINEAR_API_KEY not set (env or ~/.config/pandastack/secrets.env)")


def post(key, query, variables=None):
    body = {"query": query}
    if variables is not None:
        body["variables"] = variables
    req = urllib.request.Request(
        LINEAR_URL,
        data=json.dumps(body).encode("utf-8"),
        headers={"Authorization": key, "Content-Type": "application/json"},
    )
    try:
        with urllib.request.urlopen(req, timeout=30) as resp:
            payload = json.loads(resp.read().decode("utf-8"))
    except urllib.error.HTTPError as e:
        detail = e.read().decode("utf-8", errors="replace")[:300]
        sys.exit(f"Linear API error: HTTP {e.code} {e.reason}: {detail}")
    except urllib.error.URLError as e:
        sys.exit(f"Linear API request failed: {e.reason}")
    if payload.get("errors"):
        sys.exit("Linear API error: " + json.dumps(payload["errors"], ensure_ascii=False))
    return payload["data"]


def issue_team_number(identifier):
    m = re.match(r"^([A-Za-z]+)-(\d+)$", identifier.strip())
    if not m:
        sys.exit(f"error: bad issue identifier {identifier!r} (expected like PRO-26)")
    return m.group(1).upper(), int(m.group(2))


def render_ledger(args):
    run = args.run or "n/a"
    repo = args.repo or "n/a"
    branch = args.branch or "n/a"
    commit = args.commit or "n/a"
    pr = args.pr or "n/a"
    checks = args.checks or "n/a"
    review_url = args.review_url or "n/a"
    verdict = args.verdict or "n/a"
    return "\n".join([
        "Agent loop update",
        "",
        f"- Run: {run}",
        f"- Repo: {repo}",
        f"- Branch: `{branch}`",
        f"- Commit: `{commit}`",
        f"- PR: {pr}",
        f"- Checks: {checks}",
        f"- PandaStack review: {review_url}",
        f"- Verdict: {verdict}",
        "",
    ])


def load_body(args):
    if args.body_file:
        return pathlib.Path(args.body_file).read_text(encoding="utf-8")
    return render_ledger(args)


def main():
    ap = argparse.ArgumentParser(prog="pandastack-linear-comment")
    ap.add_argument("--issue", required=True, help="Linear issue identifier, e.g. PRO-26")
    ap.add_argument("--body-file", help="markdown file to append as the comment body")
    ap.add_argument("--run", help="agent-loop run id")
    ap.add_argument("--repo", help="owner/repo")
    ap.add_argument("--branch", help="git branch")
    ap.add_argument("--commit", help="git commit SHA")
    ap.add_argument("--pr", help="GitHub PR URL")
    ap.add_argument("--checks", help="CI/test/check summary")
    ap.add_argument("--review-url", help="GitHub PR review/comment URL")
    ap.add_argument("--verdict", help="ready for human review | blocked | needs decision | failed")
    ap.add_argument("--dry-run", action="store_true", help="print the comment, write nothing")
    ap.add_argument("--json", action="store_true", help="emit machine-readable result")
    args = ap.parse_args()

    body = load_body(args)
    if args.dry_run:
        result = {"dry_run": True, "issue": args.issue, "url": None, "body": body}
        if args.json:
            print(json.dumps(result, ensure_ascii=False, indent=2))
        else:
            print(f"DRY RUN: would append Linear comment to {args.issue}")
            print(body, end="" if body.endswith("\n") else "\n")
        return 0

    team_key, number = issue_team_number(args.issue)
    key = load_key()
    data = post(
        key,
        "query($k:String!,$n:Float!){issues(filter:{team:{key:{eq:$k}},number:{eq:$n}}){nodes{id identifier url}}}",
        {"k": team_key, "n": number},
    )
    nodes = data["issues"]["nodes"]
    if not nodes:
        sys.exit(f"error: issue {args.issue} not found")
    issue = nodes[0]
    data = post(
        key,
        "mutation($input:CommentCreateInput!){commentCreate(input:$input){success comment{id url body}}}",
        {"input": {"issueId": issue["id"], "body": body}},
    )
    cc = data.get("commentCreate", {})
    if not cc.get("success"):
        sys.exit(f"error: commentCreate returned success=false for {args.issue}")
    comment = cc["comment"]
    result = {"dry_run": False, "issue": issue["identifier"], "url": comment.get("url"), "body": comment.get("body")}
    if args.json:
        print(json.dumps(result, ensure_ascii=False, indent=2))
    else:
        print("Linear comment appended: " + (comment.get("url") or comment.get("id") or "<no-url>"))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
