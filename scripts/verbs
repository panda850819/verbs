#!/usr/bin/env python3
"""Verbs CLI: install checks, manifest sync, and bounded fresh runs. Stdlib only."""
import argparse
import hashlib
import json
import os
import re
import shlex
import stat
import subprocess
import sys
from pathlib import Path

import fresh_run


def _env_value(canonical, legacy, default=None):
    """Read the Verbs variable first, then one bounded legacy alias."""
    if canonical in os.environ:
        return os.environ[canonical]
    if legacy in os.environ:
        return os.environ[legacy]
    return default


REPO_ROOT = Path(_env_value(
    "VERBS_REPO_ROOT",
    "PANDA_VERBS_REPO_ROOT",
    str(Path(__file__).resolve().parent.parent),
)).resolve()
_DEFAULT_MANIFEST = REPO_ROOT / "manifest.toml"
MANIFEST_PATH = Path(_env_value(
    "VERBS_MANIFEST", "PANDA_VERBS_MANIFEST", str(_DEFAULT_MANIFEST)
))
DISPATCH_PATH = REPO_ROOT / "DISPATCH.md"
SKILLS_DIR = REPO_ROOT / "skills"
RESOURCE_INDEX = Path("skills/.verbs-resource-index.json")
README_PATH = Path("README.md")
README_CATALOG_BEGIN = "<!-- BEGIN GENERATED: skill-catalog -->"
README_CATALOG_END = "<!-- END GENERATED: skill-catalog -->"

_PRODUCT_KEYS = (
    "id", "display_name", "marketplace_id", "repository", "homepage",
    "description", "hero", "support", "category", "environment_prefix",
    "keywords",
)

# Schema version for the machine-readable doctor report.
SCHEMA_VERSION = 2


# ---------------------------------------------------------------------------
# Minimal TOML parser (handles manifest.toml structure; no external deps)
# ---------------------------------------------------------------------------

def _parse_toml_minimal(text):
    """Parse a subset of TOML sufficient for manifest.toml.

    Handles: [section], [section.key], key = "string", key = ["list"], bool,
    int, and a trailing inline comment (# ...) after a scalar value.
    Limitation: no multi-line values, no inline tables, no dotted keys, and
    commas inside quoted list items are not respected.
    """
    result = {}
    current = result

    for raw_line in text.splitlines():
        line = raw_line.strip()
        if not line or line.startswith("#"):
            continue

        if line.startswith("[") and line.endswith("]"):
            inner = line[1:-1]
            parts = inner.split(".")
            node = result
            for part in parts:
                node = node.setdefault(part, {})
            current = node
            continue

        if "=" in line:
            key, _, val = line.partition("=")
            key = key.strip()
            val = val.strip()
            if val.startswith('"'):
                # Quoted string: value ends at the closing quote; ignore any
                # trailing inline comment.
                end = val.find('"', 1)
                current[key] = val[1:end] if end != -1 else val[1:]
            elif val.startswith("["):
                # Single-line list: value ends at the closing bracket.
                end = val.find("]")
                inner = val[1:end] if end != -1 else val[1:]
                items = [
                    v.strip().strip('"')
                    for v in inner.split(",")
                    if v.strip().strip('"')
                ]
                current[key] = items
            else:
                # Bareword / int / bool: strip any trailing inline comment.
                val = val.split("#", 1)[0].strip()
                if val in ("true", "false"):
                    current[key] = val == "true"
                else:
                    try:
                        current[key] = int(val)
                    except ValueError:
                        current[key] = val

    return result


def load_manifest():
    """Return (ok, error_message, data)."""
    if not MANIFEST_PATH.exists():
        return False, f"manifest.toml not found at {MANIFEST_PATH}", {}
    try:
        text = MANIFEST_PATH.read_text()
    except OSError as exc:
        return False, f"Cannot read manifest.toml: {exc}", {}
    try:
        try:
            import tomllib  # Python 3.11+
            data = tomllib.loads(text)
        except ImportError:
            data = _parse_toml_minimal(text)
    except Exception as exc:
        return False, f"Failed to parse manifest.toml: {exc}", {}
    product = data.get("product")
    if not isinstance(product, dict):
        return False, "manifest.toml is missing [product]", {}
    missing = [key for key in _PRODUCT_KEYS if key not in product]
    if missing:
        return False, (
            "manifest.toml [product] is missing: " + ", ".join(missing)
        ), {}
    if not isinstance(product.get("keywords"), list):
        return False, "manifest.toml [product].keywords must be a list", {}
    return True, None, data


# ---------------------------------------------------------------------------
# Runtime skill-surface parity
# ---------------------------------------------------------------------------

def _sha256_file(path):
    if not path.is_file():
        return None
    return hashlib.sha256(path.read_bytes()).hexdigest()


def _sha256_tree(path):
    """Hash a directory deterministically from relative paths + file bytes."""
    if not path.is_dir():
        return None
    digest = hashlib.sha256()
    files = sorted(
        p for p in path.rglob("*")
        if p.is_file() and "__pycache__" not in p.parts and p.suffix != ".pyc"
    )
    for file_path in files:
        digest.update(file_path.relative_to(path).as_posix().encode("utf-8"))
        digest.update(b"\0")
        digest.update(file_path.read_bytes())
        digest.update(b"\0")
    return digest.hexdigest()


def _skill_name(path):
    try:
        text = path.read_text(encoding="utf-8")
    except OSError as exc:
        return None, f"cannot read {path}: {exc}"
    lines = text.splitlines()
    if not lines or lines[0].strip() != "---":
        return None, f"{path}: missing YAML frontmatter"
    try:
        end = next(
            index for index, line in enumerate(lines[1:], 1)
            if line.strip() == "---"
        )
    except StopIteration:
        return None, f"{path}: unterminated YAML frontmatter"
    frontmatter = "\n".join(lines[1:end])
    match = re.search(
        r"^name:\s*([a-z0-9][a-z0-9-]*)\s*$", frontmatter, re.M
    )
    if not match:
        return None, f"{path}: missing scalar frontmatter name"
    return match.group(1), None


def _scan_skill_files(files):
    names = []
    skill_files = []
    issues = []
    seen = {}
    for path in sorted(set(files)):
        name, error = _skill_name(path)
        if error:
            issues.append(error)
            continue
        names.append(name)
        skill_files.append(str(path.resolve()))
        if name in seen:
            issues.append(f"duplicate skill name {name}: {seen[name]} and {path}")
        else:
            seen[name] = path
    return {
        "skills": sorted(set(names)),
        "skill_files": skill_files,
        "issues": sorted(issues),
    }


def _scan_skill_tree(root):
    if not root.is_dir():
        return {"skills": [], "skill_files": [],
                "issues": [f"skill root missing: {root}"]}
    scan = _scan_skill_files(root.rglob("SKILL.md"))
    for bucket in sorted(p for p in root.iterdir() if p.is_dir()):
        for skill_dir in sorted(p for p in bucket.iterdir() if p.is_dir()):
            if not (skill_dir / "SKILL.md").is_file():
                scan["issues"].append(
                    f"skill directory has no SKILL.md: {skill_dir}"
                )
    scan["issues"] = sorted(set(scan["issues"]))
    return scan


def _read_json(path):
    try:
        return json.loads(path.read_text(encoding="utf-8")), None
    except (OSError, ValueError) as exc:
        return {}, f"cannot read JSON {path}: {exc}"


def _claude_config_dir():
    return Path(os.environ.get("CLAUDE_CONFIG_DIR", Path.home() / ".claude"))


def _codex_home():
    return Path(os.environ.get("CODEX_HOME", Path.home() / ".codex"))


def _codex_config_sections(path):
    """Read only plugin/marketplace receipts from Codex config.toml."""
    result = {"plugins": {}, "marketplaces": {}}
    if not path.is_file():
        return result, None
    current = None
    section_re = re.compile(
        r'^\[(plugins|marketplaces)\.(?:"([^"]+)"|([a-zA-Z0-9._-]+))\]$'
    )
    try:
        lines = path.read_text(encoding="utf-8").splitlines()
    except OSError as exc:
        return result, f"cannot read Codex config {path}: {exc}"
    for raw in lines:
        line = raw.strip()
        match = section_re.fullmatch(line)
        if match:
            family, quoted, bare = match.groups()
            key = quoted or bare
            current = result[family].setdefault(key, {})
            continue
        if line.startswith("["):
            current = None
            continue
        if current is None or "=" not in line:
            continue
        key, _, value = line.partition("=")
        key = key.strip()
        value = value.split("#", 1)[0].strip()
        if value in ("true", "false"):
            current[key] = value == "true"
        elif value.startswith('"') and value.endswith('"'):
            current[key] = value[1:-1]
    return result, None


def _receipt_drift(message, drift, path=None):
    result = _not_installed()
    result.update(
        status="drift", ok=False, path=str(path) if path else None,
        issues=[message], drift=[drift],
    )
    return result


def _registration_scan(root, manifest_rel):
    manifest_path = root / manifest_rel
    data, error = _read_json(manifest_path)
    issues = [error] if error else []
    spec = data.get("skills")
    files = []
    resolved_root = root.resolve()

    def _registered_path(item):
        candidate = (root / item).resolve()
        try:
            inside = os.path.commonpath((str(candidate), str(resolved_root))) \
                == str(resolved_root)
        except ValueError:
            inside = False
        if not inside:
            issues.append(f"registered skill path escapes plugin root: {candidate}")
            return None
        return candidate

    if isinstance(spec, list):
        for item in spec:
            if not isinstance(item, str):
                issues.append(f"registered skill path must be a string: {item!r}")
                continue
            skill_dir = _registered_path(item)
            if skill_dir is None:
                continue
            skill_file = skill_dir / "SKILL.md"
            if skill_file.is_file():
                files.append(skill_file)
            else:
                issues.append(f"registered skill has no SKILL.md: {skill_dir}")
    elif isinstance(spec, str):
        skill_root = _registered_path(spec)
        if skill_root is not None:
            if skill_root.is_dir():
                files.extend(skill_root.rglob("SKILL.md"))
            else:
                issues.append(f"registered skill root missing: {skill_root}")
    else:
        issues.append(f"{manifest_path}: skills must be a path or path list")
    scan = _scan_skill_files(files)
    scan["issues"] = sorted(set(scan["issues"] + issues))
    scan["version"] = data.get("version")
    scan["manifest"] = str(manifest_path)
    return scan


def _compare_surface(expected, scan):
    actual = set(scan["skills"])
    expected_set = set(expected)
    result = dict(scan)
    result["missing"] = sorted(expected_set - actual)
    result["extra"] = sorted(actual - expected_set)
    result["ok"] = not result["missing"] and not result["extra"] \
        and not result["issues"]
    return result


def _not_installed():
    return {
        "status": "not_installed", "ok": None, "path": None,
        "version": None, "skills": [], "missing": [], "extra": [],
        "issues": [], "dispatch_sha256": None, "hooks_sha256": None,
        "drift": [],
    }


def _migration_required(path, issue):
    result = _not_installed()
    result.update(
        status="migration_required", ok=False, path=str(path),
        issues=[issue], drift=["legacy_identity"],
    )
    return result


def _legacy_conflict(result, issue):
    conflicted = dict(result)
    conflicted["status"] = "drift"
    conflicted["ok"] = False
    conflicted["issues"] = list(result["issues"]) + [issue]
    conflicted["drift"] = sorted(set(result["drift"] + ["legacy_identity"]))
    return conflicted


def _installed_cache(host, cache_root, expected, expected_version,
                     source_dispatch, source_hooks):
    manifest_rel = (Path(".claude-plugin") / "plugin.json"
                    if host == "claude"
                    else Path(".codex-plugin") / "plugin.json")
    registration = _compare_surface(
        expected, _registration_scan(cache_root, manifest_rel)
    )
    dispatch_hash = _sha256_file(cache_root / "DISPATCH.md")
    hooks_hash = _sha256_tree(cache_root / "hooks")
    drift = []
    if not registration["ok"]:
        drift.append("skills")
    if registration.get("version") != expected_version:
        drift.append("version")
    if dispatch_hash != source_dispatch:
        drift.append("dispatch_sha256")
    if hooks_hash != source_hooks:
        drift.append("hooks_sha256")
    return {
        "status": "ok" if not drift else "drift",
        "ok": not drift,
        "path": str(cache_root),
        "version": registration.get("version"),
        "skills": registration["skills"],
        "missing": registration["missing"],
        "extra": registration["extra"],
        "issues": registration["issues"],
        "dispatch_sha256": dispatch_hash,
        "hooks_sha256": hooks_hash,
        "drift": drift,
    }


def _claude_installed(expected, expected_version, source_dispatch, source_hooks,
                      product):
    def _registry_drift(message):
        result = _not_installed()
        result.update(
            status="drift", ok=False, issues=[message], drift=["registry"]
        )
        return result

    config_dir = _claude_config_dir()
    registry = config_dir / "plugins" / "installed_plugins.json"
    if not registry.is_file():
        return _not_installed()
    data, error = _read_json(registry)
    if error:
        return _registry_drift(error)
    plugins = data.get("plugins")
    if not isinstance(plugins, dict):
        return _registry_drift("Claude registry plugins field is not an object")
    plugin_key = f"{product['id']}@{product['marketplace_id']}"
    records = plugins.get(plugin_key, [])
    legacy_records = plugins.get("pandastack@pandastack", [])
    settings_path = config_dir / "settings.json"
    settings, settings_error = _read_json(settings_path) \
        if settings_path.is_file() else ({}, None)
    if settings_error:
        return _registry_drift(settings_error)
    enabled_plugins = settings.get("enabledPlugins", {})
    if enabled_plugins and not isinstance(enabled_plugins, dict):
        return _registry_drift("Claude settings enabledPlugins is not an object")
    if not records:
        if legacy_records:
            path = next(
                (item.get("installPath") for item in legacy_records
                 if isinstance(item, dict) and item.get("installPath")),
                registry,
            )
            return _migration_required(
                path, "legacy pandastack@pandastack install found; install verbs@verbs"
            )
        return _not_installed()
    if not isinstance(records, list) or not all(
        isinstance(item, dict) for item in records
    ):
        return _registry_drift("Claude registry plugin records are malformed")
    record = sorted(
        records,
        key=lambda item: item.get("lastUpdated", item.get("installedAt", "")),
    )[-1]
    install_path = record.get("installPath")
    if not install_path:
        return _registry_drift("Claude registry entry has no installPath")
    if enabled_plugins.get(plugin_key) is not True:
        return _receipt_drift(
            f"Claude plugin {plugin_key} is installed but not enabled",
            "enabled", install_path,
        )
    result = _installed_cache(
        "claude", Path(install_path), expected, expected_version,
        source_dispatch, source_hooks,
    )
    if legacy_records:
        result = _legacy_conflict(
            result,
            "legacy pandastack@pandastack is also installed; remove stale v3 policies",
        )
    return result


def _codex_installed(expected, expected_version, source_dispatch, source_hooks,
                     product):
    def _version_key(path):
        parts = path.name.split(".")
        if parts and all(part.isdigit() for part in parts):
            return 1, tuple(int(part) for part in parts)
        return 0, path.name

    codex_home = _codex_home()
    config, config_error = _codex_config_sections(codex_home / "config.toml")
    if config_error:
        return _receipt_drift(config_error, "registry")
    plugin_key = f"{product['id']}@{product['marketplace_id']}"
    plugin_state = config["plugins"].get(plugin_key, {}).get("enabled")
    legacy_state = config["plugins"].get("pandastack@pandastack", {}).get("enabled")

    legacy_cache = codex_home / "plugins" / "cache" / \
        "pandastack" / "pandastack"
    legacy_standalone = codex_home / "skills" / "pandastack"
    base = codex_home / "plugins" / "cache" / \
        product["marketplace_id"] / product["id"]
    versions = sorted((p for p in base.iterdir() if p.is_dir()), key=_version_key) \
        if base.is_dir() else []
    expected_path = base / str(expected_version)
    if plugin_state is not True:
        if legacy_state is not None or legacy_cache.exists() or legacy_standalone.exists():
            path = legacy_cache if legacy_cache.exists() else codex_home / "config.toml"
            return _migration_required(
                path, "legacy pandastack install found; install and enable verbs@verbs"
            )
        if versions or plugin_state is False:
            return _receipt_drift(
                f"Codex plugin {plugin_key} cache exists but is not enabled",
                "enabled", base,
            )
        return _not_installed()

    if expected_path.is_dir():
        cache_root = expected_path
    elif versions:
        cache_root = versions[-1]
    else:
        marketplace = config["marketplaces"].get(product["marketplace_id"], {})
        local_source = marketplace.get("source") \
            if marketplace.get("source_type") == "local" else None
        local_root = Path(local_source) if local_source else None
        standalone = codex_home / "skills" / product["id"]
        if local_root is not None and local_root.is_dir():
            cache_root = local_root
        elif standalone.exists():
            scan = _compare_surface(expected, _scan_skill_tree(standalone))
            return {
                "status": "drift", "ok": False, "path": str(standalone),
                "version": None, "skills": scan["skills"],
                "missing": scan["missing"], "extra": scan["extra"],
                "issues": scan["issues"], "dispatch_sha256": None,
                "hooks_sha256": None,
                "drift": ["version", "dispatch_sha256", "hooks_sha256"]
                + ([] if scan["ok"] else ["skills"]),
            }
        else:
            return _receipt_drift(
                f"Codex plugin {plugin_key} is enabled but no installed source resolves",
                "registry", codex_home / "config.toml",
            )
    result = _installed_cache(
        "codex", cache_root, expected, expected_version,
        source_dispatch, source_hooks,
    )
    if legacy_state is not None or legacy_cache.exists() or legacy_standalone.exists():
        result = _legacy_conflict(
            result,
            "legacy pandastack install also exists; remove stale v3 policies",
        )
    return result


def build_runtime_surface(manifest_data):
    product = manifest_data["product"]
    expected = sorted(manifest_data.get("skill", {}).keys())
    expected_version = manifest_data.get("manifest", {}).get("version")
    recursive = _compare_surface(expected, _scan_skill_tree(SKILLS_DIR))
    claude = _compare_surface(expected, _registration_scan(
        REPO_ROOT, Path(".claude-plugin") / "plugin.json"
    ))
    codex = _compare_surface(expected, _registration_scan(
        REPO_ROOT, Path(".codex-plugin") / "plugin.json"
    ))
    versions = {
        "manifest": expected_version,
        "claude": claude.get("version"),
        "codex": codex.get("version"),
    }
    version_drift = sorted(
        host for host in ("claude", "codex")
        if versions[host] != expected_version
    )
    dispatch_hash = _sha256_file(DISPATCH_PATH)
    hooks_hash = _sha256_tree(REPO_ROOT / "hooks")
    artifact_issues = []
    if dispatch_hash is None:
        artifact_issues.append(f"missing dispatch file: {DISPATCH_PATH}")
    if hooks_hash is None:
        artifact_issues.append(f"missing hooks directory: {REPO_ROOT / 'hooks'}")
    source_ok = recursive["ok"] and claude["ok"] and codex["ok"] \
        and not version_drift and not artifact_issues
    source = {
        "ok": source_ok,
        "expected": expected,
        "source_recursive": recursive,
        "claude_registration": claude,
        "codex_registration": codex,
        "versions": versions,
        "version_drift": version_drift,
        "dispatch_sha256": dispatch_hash,
        "hooks_sha256": hooks_hash,
        "issues": artifact_issues,
        "skill_files": recursive["skill_files"],
    }
    installed = {
        "claude": _claude_installed(
            expected, expected_version, dispatch_hash, hooks_hash, product
        ),
        "codex": _codex_installed(
            expected, expected_version, dispatch_hash, hooks_hash, product
        ),
    }
    installed_problem = any(
        item["status"] in ("drift", "migration_required")
        for item in installed.values()
    )
    return {
        "ok": source_ok and not installed_problem,
        "expected": expected,
        "source": source,
        "installed": installed,
    }


def check_manifest_skills(manifest_data, runtime_surface):
    """Return manifest check dict with skill counts and drift info."""
    skill_section = manifest_data.get("skill", {})

    core = [k for k, v in skill_section.items()
            if isinstance(v, dict) and v.get("tier") == "core"]
    ext = [k for k, v in skill_section.items()
           if isinstance(v, dict) and v.get("tier") == "ext"]

    recursive = runtime_surface["source"]["source_recursive"]
    disk_skills = set(recursive["skills"])
    manifest_skills = set(skill_section.keys())
    missing_on_disk = sorted(manifest_skills - disk_skills)
    missing_in_manifest = sorted(disk_skills - manifest_skills)

    return {
        "ok": not missing_on_disk and not missing_in_manifest
        and not recursive["issues"],
        "skill_counts": {
            "total": len(skill_section),
            "core": len(core),
            "ext": len(ext),
        },
        "drift": {
            "missing_on_disk": missing_on_disk,
            "missing_in_manifest": missing_in_manifest,
            "issues": recursive["issues"],
        },
    }


# ---------------------------------------------------------------------------
# Subcommand: doctor
# ---------------------------------------------------------------------------


def _codex_live_hook_trust(installed):
    if installed["status"] != "ok" or not installed.get("path"):
        return {
            "ok": False,
            "status": "not_ready",
            "issues": ["Codex cache parity must be exact before live hook trust"],
        }

    smoke = REPO_ROOT / "scripts" / "codex-hook-smoke.py"
    if not smoke.is_file():
        return {
            "ok": False,
            "status": "unavailable",
            "issues": [f"missing live hook verifier: {smoke}"],
        }

    allowed_env = {
        "PATH", "LANG", "LC_ALL", "LC_CTYPE",
        "TMPDIR", "TMP", "TEMP", "SYSTEMROOT",
    }
    env = {key: value for key, value in os.environ.items() if key in allowed_env}

    codex_home = _codex_home().resolve()
    installed_root = Path(installed["path"]).resolve()
    command = [
        sys.executable,
        str(smoke),
        "--inventory-only",
        "--require-trusted",
        "--codex-home",
        str(codex_home),
    ]
    try:
        installed_root.relative_to((codex_home / "plugins").resolve())
    except ValueError:
        command.append("--allow-external-installed-root")
    command.extend([str(Path.home()), str(installed_root)])
    proc = subprocess.run(
        command,
        env=env,
        text=True,
        capture_output=True,
        check=False,
    )
    if proc.returncode == 0:
        return {"ok": True, "status": "trusted", "issues": []}

    message = next(
        (line.strip() for line in proc.stderr.splitlines() if line.strip()),
        "Codex live hook trust verification failed",
    )
    return {"ok": False, "status": "untrusted", "issues": [message]}


def run_doctor(args):
    manifest_ok, manifest_err, manifest_data = load_manifest()
    if not manifest_ok:
        print(f"ERROR: {manifest_err}", file=sys.stderr)
        sys.exit(1)

    host = getattr(args, "host", "auto") or "auto"
    strict = getattr(args, "strict", False)
    live_hooks = getattr(args, "live_hooks", False)
    if strict and host not in ("claude", "codex"):
        print("ERROR: --strict requires --host claude or --host codex",
              file=sys.stderr)
        sys.exit(2)
    if live_hooks and host != "codex":
        print("ERROR: --live-hooks requires --host codex", file=sys.stderr)
        sys.exit(2)

    runtime_surface = build_runtime_surface(manifest_data)
    manifest_check = check_manifest_skills(manifest_data, runtime_surface)
    output = {
        "schema_version": SCHEMA_VERSION,
        "product": manifest_data["product"],
        "repo": str(REPO_ROOT),
        "host": host,
        "checks": {
            "manifest": manifest_check,
            "runtime_surface": runtime_surface,
        },
    }
    if live_hooks:
        output["checks"]["live_hooks"] = _codex_live_hook_trust(
            runtime_surface["installed"]["codex"])
    strict_fail = strict and (
        not runtime_surface["source"]["ok"]
        or runtime_surface["installed"][host]["status"] != "ok"
        or (live_hooks and not output["checks"]["live_hooks"]["ok"])
    )

    if args.json:
        print(json.dumps(output, indent=2))
    else:
        _print_doctor_text(output)
    if strict_fail:
        sys.exit(1)


def _print_doctor_text(out):
    display_name = out["product"]["display_name"]
    print()
    print(f"{display_name} doctor")
    print("=" * (len(display_name) + len(" doctor")))
    print(f"Repo: {out['repo']}")
    print()

    manifest = out["checks"]["manifest"]
    counts = manifest["skill_counts"]
    symbol = "+" if manifest["ok"] else "!"
    print(f"[{symbol}] manifest: {'exact' if manifest['ok'] else 'drift detected'}")
    print(f"    Core: {counts['core']}  Ext: {counts['ext']}  Total: {counts['total']}")

    surface = out["checks"]["runtime_surface"]
    symbol = "+" if surface["source"]["ok"] else "!"
    print(f"[{symbol}] source registrations: "
          f"{'exact' if surface['source']['ok'] else 'drift detected'}")
    for host in ("claude", "codex"):
        installed = surface["installed"][host]
        symbol = "+" if installed["status"] == "ok" else \
            ("~" if installed["status"] == "not_installed" else "!")
        print(f"[{symbol}] {host} install: {installed['status']}")
        for issue in installed["issues"]:
            print(f"    {issue}")
        if installed["drift"]:
            print(f"    Drift: {', '.join(installed['drift'])}")
    if "live_hooks" in out["checks"]:
        live = out["checks"]["live_hooks"]
        symbol = "+" if live["ok"] else "!"
        print(f"[{symbol}] codex live hooks: {live['status']}")
        for issue in live["issues"]:
            print(f"    {issue}")
    print()


# ---------------------------------------------------------------------------
# Subcommand: init
# ---------------------------------------------------------------------------

def run_init(args):
    manifest_ok, manifest_err, manifest_data = load_manifest()
    if not manifest_ok:
        print(f"ERROR: {manifest_err}", file=sys.stderr)
        sys.exit(1)
    product = manifest_data["product"]
    plugin_selector = f"{product['id']}@{product['marketplace_id']}"
    quoted_repo = shlex.quote(str(REPO_ROOT))
    host = getattr(args, "host", None) or "claude"
    dry_run = getattr(args, "dry_run", False)

    if not dry_run:
        print(
            "init is report-only. Re-run with --dry-run, then execute the "
            "printed host commands explicitly.",
            file=sys.stderr,
        )
        sys.exit(1)

    # Dry run output
    print()
    print(f"verbs init --host {host} --dry-run")
    print(f"Repo: {REPO_ROOT}")
    print()

    if host == "claude":
        print(f"Commands to install {product['display_name']} in Claude Code:")
        print(f"  claude plugin validate {quoted_repo}")
        print(f"  claude plugin marketplace add {quoted_repo} --scope user")
        print(f"  claude plugin install {plugin_selector} --scope user")
        print("  # Run /reload-plugins in Claude Code.")
    elif host == "codex":
        print(f"Commands to install {product['display_name']} in Codex CLI:")
        print(f"  codex plugin marketplace add {quoted_repo} --json")
        print(f"  codex plugin add {plugin_selector} --json")
        print("  # Restart Codex before verification.")
    elif host == "hermes":
        selected_source = shlex.quote(
            str(REPO_ROOT / "skills" / "<bucket>" / "<skill>")
        )
        print(f"Commands to import {product['display_name']} skills into Hermes:")
        print("  mkdir -p $HOME/.hermes/skills")
        print(f"  SKILL_DIR={selected_source}")
        print("  SKILL_NAME='<skill>'")
        print('  ln -sfn "$SKILL_DIR" "$HOME/.hermes/skills/$SKILL_NAME"')
        print("  # Repeat only for each reviewed, selected skill.")
        print("See docs/HERMES.md for the direct-import support model.")
        print("No mutation of ~/.hermes will be performed by this command.")
    else:
        print(f"Unknown host: {host}. Use --host claude|codex|hermes",
              file=sys.stderr)
        sys.exit(2)

    print()


# ---------------------------------------------------------------------------
# Subcommand: sync (manifest.toml -> derived files)
# ---------------------------------------------------------------------------
#
# manifest.toml is the only hand-authored product/skill identity. Host loader
# manifests and the README skill catalog are committed generated files.


def _sync_root():
    """Repo root the JSON targets are resolved under. Overridable for tests."""
    override = _env_value("VERBS_SYNC_ROOT", "PANDA_VERBS_SYNC_ROOT")
    return Path(override) if override else REPO_ROOT


def _manifest_skill_dirs(manifest_data):
    """Return manifest skill names mapped to repo-relative directories."""
    expected = set(manifest_data.get("skill", {}))
    found = {}
    for skill_file in SKILLS_DIR.rglob("SKILL.md"):
        name, error = _skill_name(skill_file)
        if error:
            raise ValueError(error)
        if name in found:
            raise ValueError(f"duplicate skill name {name}")
        found[name] = skill_file.parent.relative_to(REPO_ROOT).as_posix()
    if set(found) != expected:
        missing = sorted(expected - set(found))
        extra = sorted(set(found) - expected)
        raise ValueError(f"manifest skill paths drift: missing={missing} extra={extra}")
    return {name: Path(found[name]) for name in sorted(expected)}


def _manifest_skill_paths(manifest_data):
    """Return deterministic Claude registration paths for manifest skills."""
    directories = _manifest_skill_dirs(manifest_data)
    return [f"./{directories[name].as_posix()}" for name in sorted(directories)]


def _generated_resources(manifest_data):
    """Render committed skill-local resource copies from manifest.toml."""
    skill_specs = manifest_data.get("skill", {})
    skill_dirs = _manifest_skill_dirs(manifest_data)
    known_skills = set(skill_specs)
    generated = {}

    for name in sorted(skill_specs):
        spec = skill_specs[name]
        if not isinstance(spec, dict):
            raise ValueError(f"manifest skill {name} must be a table")
        resources = spec.get("resources")
        composes = spec.get("composes")
        if not isinstance(resources, list):
            raise ValueError(f"manifest skill {name} resources must be a list")
        if not isinstance(composes, list):
            raise ValueError(f"manifest skill {name} composes must be a list")
        if any(not isinstance(resource, str) for resource in resources):
            raise ValueError(
                f"manifest skill {name} resource paths must be strings"
            )
        if any(not isinstance(companion, str) for companion in composes):
            raise ValueError(
                f"manifest skill {name} composed skills must be strings"
            )
        if len(resources) != len(set(resources)):
            raise ValueError(f"manifest skill {name} has duplicate resources")
        if len(composes) != len(set(composes)):
            raise ValueError(f"manifest skill {name} has duplicate composes")

        for companion in composes:
            if companion == name:
                raise ValueError(f"manifest skill {name} cannot compose itself")
            if companion not in known_skills:
                raise ValueError(
                    f"manifest skill {name} composes missing skill {companion}"
                )

        for resource in resources:
            if not resource:
                raise ValueError(
                    f"manifest skill {name} resource paths must be strings"
                )
            relative = Path(resource)
            if relative.is_absolute() or ".." in relative.parts:
                raise ValueError(
                    f"manifest skill {name} resource escapes repo: {resource}"
                )
            source = REPO_ROOT / relative
            try:
                _assert_no_symlink_components(REPO_ROOT, source)
            except ValueError as exc:
                raise ValueError(
                    f"manifest skill {name} resource is unsafe: {exc}"
                ) from exc
            if not source.is_file():
                raise ValueError(
                    f"manifest skill {name} resource missing: {resource}"
                )
            destination = skill_dirs[name] / relative
            if destination.name in {"SKILL.md", "eval.md"}:
                raise ValueError(
                    f"manifest skill {name} resource collides with {destination.name}"
                )
            if destination in generated:
                raise ValueError(
                    f"generated resource collision at {destination.as_posix()}"
                )
            generated[destination] = source.read_bytes()

    return generated


def _resource_index_data(resources):
    """Return the generated-resource ownership index."""
    return {
        "schema": 1,
        "files": [path.as_posix() for path in sorted(resources)],
    }


def _load_resource_index(root):
    """Read and validate the previous generated-resource ownership index."""
    path = root / RESOURCE_INDEX
    try:
        _assert_no_symlink_components(root, path)
    except ValueError as exc:
        raise ValueError(f"resource index is unsafe: {exc}") from exc
    if not path.exists():
        return _resource_index_data({})
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
    except (OSError, ValueError) as exc:
        raise ValueError(f"cannot read resource index: {exc}") from exc
    if not isinstance(data, dict) or data.get("schema") != 1:
        raise ValueError("resource index must use schema 1")
    files = data.get("files")
    if not isinstance(files, list) or any(not isinstance(item, str) for item in files):
        raise ValueError("resource index files must be a string list")
    if len(files) != len(set(files)):
        raise ValueError("resource index has duplicate files")
    for item in files:
        relative = Path(item)
        if (
            relative.is_absolute()
            or ".." in relative.parts
            or not relative.parts
            or relative.parts[0] != "skills"
            or relative.name == "SKILL.md"
        ):
            raise ValueError(f"resource index has unsafe path: {item}")
    return data


def _validate_stale_resource_deletions(root, stale_paths, manifest_data):
    """Authorize stale deletion only for unchanged copies of canonical resources."""
    skill_dirs = list(_manifest_skill_dirs(manifest_data).values())
    deletions = []
    for relative in sorted(stale_paths):
        tail = None
        for skill_dir in skill_dirs:
            try:
                tail = relative.relative_to(skill_dir)
                break
            except ValueError:
                continue
        # A whole-skill retirement removes its directory from the current
        # manifest before sync can prune the old portable resource copies. In
        # that case derive only the resource tail below
        # skills/<bucket>/<skill>/ and keep the same canonical-byte proof used
        # for active skills. A poisoned index still fails when REPO_ROOT/tail
        # is absent or the destination bytes differ.
        if tail is None and len(relative.parts) >= 4:
            tail = Path(*relative.parts[3:])
        if tail is None or not tail.parts or tail.name == "SKILL.md":
            raise ValueError(
                f"stale resource is outside a known skill directory: {relative}"
            )

        source = REPO_ROOT / tail
        try:
            _assert_no_symlink_components(REPO_ROOT, source)
        except ValueError as exc:
            raise ValueError(
                f"stale resource canonical source is unsafe: {exc}"
            ) from exc
        if not source.is_file():
            raise ValueError(
                f"stale resource has no canonical source: {relative}"
            )

        destination = root / relative
        try:
            _assert_no_symlink_components(root, destination)
        except ValueError as exc:
            raise ValueError(f"stale generated resource is unsafe: {exc}") from exc
        if not destination.exists():
            continue
        if not destination.is_file():
            raise ValueError(f"stale generated resource is not a file: {relative}")
        if destination.read_bytes() != source.read_bytes():
            raise ValueError(
                f"stale generated resource differs from canonical source: {relative}"
            )
        deletions.append(relative)
    return deletions


def _generated_loaders(manifest_data):
    """Render every host loader document from manifest.toml."""
    product = manifest_data["product"]
    version = manifest_data["manifest"]["version"]
    total = len(manifest_data.get("skill", {}))
    paths = _manifest_skill_paths(manifest_data)
    description = f"{product['description']} Includes {total} composable skills."
    long_description = (
        f"{description} {product['support']} Skills cover clarification, "
        "execution, debugging, UI, review, QA, shipping, cross-model judgment, "
        "trust gates, writing, and skill construction."
    )
    author = {"name": "Panda Zeng"}
    keywords = list(product["keywords"])
    plugin_id = product["id"]
    marketplace_id = product["marketplace_id"]
    repository_url = f"https://github.com/{product['repository']}"

    claude_plugin = {
        "name": plugin_id,
        "description": description,
        "version": version,
        "author": author,
        "homepage": product["homepage"],
        "repository": repository_url,
        "keywords": keywords,
        "skills": paths,
    }
    claude_marketplace = {
        "$schema": "https://anthropic.com/claude-code/marketplace.schema.json",
        "name": marketplace_id,
        "description": product["hero"],
        "owner": author,
        "plugins": [{
            "name": plugin_id,
            "description": description,
            "source": ".",
            "category": "development",
            "homepage": product["homepage"],
        }],
    }
    codex_plugin = {
        "name": plugin_id,
        "version": version,
        "description": description,
        "author": {
            "name": "Panda Zeng",
            "url": "https://github.com/panda850819",
        },
        "homepage": product["homepage"],
        "repository": repository_url,
        "license": "MIT",
        "keywords": keywords,
        "skills": "./skills/",
        "interface": {
            "displayName": product["display_name"],
            "shortDescription": product["hero"],
            "longDescription": long_description,
            "developerName": "Panda Zeng",
            "category": product["category"],
            "capabilities": ["Interactive", "Read", "Write"],
            "defaultPrompt": [
                "Help me clarify and plan this change.",
                "Review and ship this branch with evidence.",
                "Find the root cause before changing the code.",
            ],
        },
    }
    agents_marketplace = {
        "name": marketplace_id,
        "interface": {"displayName": product["display_name"]},
        "plugins": [{
            "name": plugin_id,
            "source": {"source": "local", "path": "."},
            "policy": {
                "installation": "AVAILABLE",
                "authentication": "ON_INSTALL",
            },
            "category": product["category"],
        }],
    }
    return {
        Path(".claude-plugin/plugin.json"): claude_plugin,
        Path(".claude-plugin/marketplace.json"): claude_marketplace,
        Path(".codex-plugin/plugin.json"): codex_plugin,
        Path(".agents/plugins/marketplace.json"): agents_marketplace,
    }


def _markdown_cell(value):
    """Render one compact, pipe-safe Markdown table cell."""
    return " ".join(value.split()).replace("|", r"\|")


def _generated_readme_catalog(manifest_data):
    """Render the public skill catalog from manifest insertion order."""
    lines = [
        "| Skill | Tier | Purpose |",
        "|---|---|---|",
    ]
    for name, spec in manifest_data.get("skill", {}).items():
        if not isinstance(spec, dict):
            raise ValueError(f"manifest skill {name} must be a table")
        tier = spec.get("tier")
        description = spec.get("description")
        if not isinstance(tier, str) or not tier:
            raise ValueError(f"manifest skill {name} tier must be a string")
        if not isinstance(description, str) or not description:
            raise ValueError(
                f"manifest skill {name} description must be a string"
            )
        lines.append(
            f"| `/verbs:{_markdown_cell(name)}` "
            f"| {_markdown_cell(tier)} "
            f"| {_markdown_cell(description)} |"
        )
    return "\n".join(lines)


def _replace_generated_block(text, begin, end, body):
    """Replace one marker-bounded block while preserving all other prose."""
    if text.count(begin) != 1 or text.count(end) != 1:
        raise ValueError(
            f"{README_PATH} must contain exactly one {begin} / {end} block"
        )
    start = text.index(begin)
    finish = text.index(end)
    if start >= finish:
        raise ValueError(f"{README_PATH} generated markers are out of order")
    return (
        text[:start]
        + begin
        + "\n"
        + body
        + "\n"
        + end
        + text[finish + len(end):]
    )


def _write_json_nofollow(path, data):
    """Write pretty JSON + trailing newline, refusing to follow a symlink."""
    if path.is_symlink():
        raise OSError(f"refusing to write through symlink: {path}")
    path.parent.mkdir(parents=True, exist_ok=True)
    fd = os.open(
        str(path), os.O_WRONLY | os.O_CREAT | os.O_TRUNC | os.O_NOFOLLOW, 0o644
    )
    with os.fdopen(fd, "w") as fh:
        os.fchmod(fh.fileno(), 0o644)
        fh.write(json.dumps(data, indent=2) + "\n")


def _assert_no_symlink_components(root, path):
    """Reject a path when it escapes root or any existing component is a symlink."""
    root = Path(root)
    path = Path(path)
    try:
        relative = path.relative_to(root)
    except ValueError as exc:
        raise ValueError(f"path escapes root: {path}") from exc
    current = root
    if current.is_symlink():
        raise ValueError(f"symlink component: {current}")
    for part in relative.parts:
        current = current / part
        if current.is_symlink():
            raise ValueError(f"symlink component: {current}")


def _write_bytes_nofollow(path, data):
    """Write bytes while refusing to follow a destination symlink."""
    if path.is_symlink():
        raise OSError(f"refusing to write through symlink: {path}")
    path.parent.mkdir(parents=True, exist_ok=True)
    fd = os.open(
        str(path), os.O_WRONLY | os.O_CREAT | os.O_TRUNC | os.O_NOFOLLOW, 0o644
    )
    with os.fdopen(fd, "wb") as fh:
        os.fchmod(fh.fileno(), 0o644)
        fh.write(data)


def run_sync(args):
    manifest_ok, manifest_err, manifest_data = load_manifest()
    if not manifest_ok:
        print(f"ERROR: {manifest_err}", file=sys.stderr)
        sys.exit(1)

    version = manifest_data["manifest"].get("version")
    total = len(manifest_data.get("skill", {}))
    if not version:
        print("ERROR: no [manifest] version in manifest.toml", file=sys.stderr)
        sys.exit(1)
    try:
        generated = _generated_loaders(manifest_data)
        resources = _generated_resources(manifest_data)
    except ValueError as exc:
        print(f"ERROR: {exc}", file=sys.stderr)
        sys.exit(1)

    check = getattr(args, "check", False)
    root = _sync_root()
    readme_path = root / README_PATH
    try:
        _assert_no_symlink_components(root, readme_path)
        readme_text = readme_path.read_text(encoding="utf-8")
        expected_readme = _replace_generated_block(
            readme_text,
            README_CATALOG_BEGIN,
            README_CATALOG_END,
            _generated_readme_catalog(manifest_data),
        )
    except (OSError, ValueError) as exc:
        print(f"ERROR: cannot render {README_PATH}: {exc}", file=sys.stderr)
        sys.exit(1)
    try:
        previous_resource_index = _load_resource_index(root)
    except ValueError as exc:
        print(f"ERROR: {exc}", file=sys.stderr)
        sys.exit(1)
    expected_resource_index = _resource_index_data(resources)
    resource_index_path = root / RESOURCE_INDEX
    resource_index_mode_drift = (
        resource_index_path.is_file()
        and stat.S_IMODE(resource_index_path.stat().st_mode) != 0o644
    )
    previous_resource_paths = {
        Path(item) for item in previous_resource_index["files"]
    }
    stale_resource_paths = previous_resource_paths - set(resources)
    try:
        stale_resource_deletions = _validate_stale_resource_deletions(
            root, stale_resource_paths, manifest_data
        )
    except ValueError as exc:
        print(f"ERROR: {exc}", file=sys.stderr)
        sys.exit(1)
    all_issues = []
    written = []
    if readme_text != expected_readme:
        all_issues.append(
            f"{README_PATH}: generated skill catalog differs from manifest render"
        )
        if not check:
            try:
                _write_bytes_nofollow(
                    readme_path, expected_readme.encode("utf-8")
                )
            except OSError as exc:
                print(f"ERROR: {exc}", file=sys.stderr)
                sys.exit(1)
            written.append(str(README_PATH))

    for relative, data in generated.items():
        path = root / relative
        current = None
        if path.is_file():
            try:
                current = json.loads(path.read_text(encoding="utf-8"))
            except (OSError, ValueError) as exc:
                all_issues.append(f"{relative}: cannot read generated JSON: {exc}")
        if current == data:
            continue
        all_issues.append(f"{relative}: differs from manifest render")
        if not check:
            try:
                _write_json_nofollow(path, data)
            except OSError as exc:
                print(f"ERROR: {exc}", file=sys.stderr)
                sys.exit(1)
            written.append(str(relative))

    for relative, data in resources.items():
        path = root / relative
        try:
            _assert_no_symlink_components(root, path)
        except ValueError as exc:
            print(f"ERROR: generated resource is unsafe: {exc}", file=sys.stderr)
            sys.exit(1)
        try:
            current = path.read_bytes() if path.is_file() else None
        except OSError as exc:
            all_issues.append(f"{relative}: cannot read generated resource: {exc}")
            current = None
        mode_drift = (
            path.is_file() and stat.S_IMODE(path.stat().st_mode) != 0o644
        )
        if current == data and not mode_drift:
            continue
        issue = "mode differs from 0644" if current == data else "differs from canonical resource"
        all_issues.append(f"{relative}: {issue}")
        if not check:
            try:
                _write_bytes_nofollow(path, data)
            except OSError as exc:
                print(f"ERROR: {exc}", file=sys.stderr)
                sys.exit(1)
            written.append(str(relative))

    if previous_resource_index != expected_resource_index or resource_index_mode_drift:
        all_issues.append(f"{RESOURCE_INDEX}: differs from manifest resources")
        for relative in sorted(stale_resource_paths):
            all_issues.append(f"{relative}: stale generated resource")

    if not check:
        for relative in stale_resource_deletions:
            path = root / relative
            path.unlink()
            written.append(f"removed:{relative}")
        if previous_resource_index != expected_resource_index or resource_index_mode_drift:
            index_path = root / RESOURCE_INDEX
            try:
                _assert_no_symlink_components(root, index_path)
                _write_json_nofollow(index_path, expected_resource_index)
            except (OSError, ValueError) as exc:
                print(f"ERROR: {exc}", file=sys.stderr)
                sys.exit(1)
            written.append(str(RESOURCE_INDEX))

    if check:
        if all_issues:
            print("FAIL: derived files out of sync with manifest.toml:")
            for issue in all_issues:
                print(f"  {issue}")
            print("  Fix: scripts/verbs sync")
            sys.exit(1)
        print(f"OK: derived files in sync (version {version}, {total} skills)")
        return

    if written:
        for issue in all_issues:
            print(f"synced: {issue}")
        print(f"Synced {len(written)} file(s) to version {version}, "
              f"{total} skills: {', '.join(written)}")
    else:
        print(f"OK: already in sync (version {version}, {total} skills)")


# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------

def main():
    parser = argparse.ArgumentParser(
        prog="verbs",
        description="Verbs CLI: install checks, manifest sync, and fresh runs",
    )
    sub = parser.add_subparsers(dest="command")

    doc = sub.add_parser("doctor", help="Check source and installed plugin parity")
    doc.add_argument("--json", action="store_true", help="Emit JSON")
    doc.add_argument(
        "--host",
        choices=["claude", "codex", "auto"],
        default="auto",
        help="Host runtime context (default: auto)",
    )
    doc.add_argument(
        "--strict",
        action="store_true",
        help="Exit nonzero unless the selected Claude/Codex cache matches source",
    )
    doc.add_argument(
        "--live-hooks",
        action="store_true",
        help="With --host codex, verify all installed Verbs hooks are trusted",
    )
    ini = sub.add_parser("init", help="Print host install commands")
    ini.add_argument(
        "--host",
        choices=["claude", "codex", "hermes"],
        default="claude",
        help="Target host (default: claude)",
    )
    ini.add_argument("--dry-run", action="store_true",
                     help="Print commands without running them")

    syn = sub.add_parser(
        "sync",
        help="Regenerate derived files from manifest.toml",
    )
    syn.add_argument(
        "--check",
        action="store_true",
        help="Exit nonzero if derived files drift from manifest.toml (no writes)",
    )

    fresh_run.add_parser(sub)

    sub.add_parser("help", help="Show this help message")

    args = parser.parse_args()

    if args.command == "doctor":
        run_doctor(args)
    elif args.command == "init":
        run_init(args)
    elif args.command == "sync":
        run_sync(args)
    elif hasattr(args, "handler"):
        sys.exit(args.handler(args))
    elif args.command == "help":
        parser.print_help()
    elif args.command is None:
        parser.print_help()
    else:
        parser.print_help()
        sys.exit(2)


if __name__ == "__main__":
    main()
