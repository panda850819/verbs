#!/usr/bin/env python3
"""pandastack-drive — the scheduler's daily driver (executor).

Reduces EVERY project's pandastack-state to its active work-items, decides the
next step, and classifies it:

  AUTO  — next phase is reversible analysis (PLAN / VERIFY / REVIEW). Safe to run
          unattended; produces plans/reports, no commits/pushes.
  GATE  — next phase needs a human: GATE (a decision), BUILD (writes code), or
          SHIP (publishes). Surfaced, never auto-run.
  PAUSED— item is frozen/parked. Skipped.

This encodes Panda's rule directly: reversible -> auto-advance, irreversible /
decision -> human gate. The driver NEVER auto-runs a mutating or publishing phase.

  pandastack-drive                 # surface today's queue (default; read-only)
  pandastack-drive --json
  pandastack-drive --run           # Stage 2: spawn the AUTO skills. Currently DRY
                                   # (prints the command it would run) until Panda
                                   # sets the autonomy envelope + headless wiring.
"""
import argparse
import glob
import json
import os
import re
import subprocess
import sys
import tempfile

HERE = os.path.dirname(os.path.abspath(__file__))
STATE = os.path.join(HERE, "pandastack-state")
PROJECTS_DIR = os.path.expanduser("~/.pandastack/projects")

NEXT_PHASE = {"DEFINE": "PLAN", "PLAN": "GATE", "GATE": "BUILD", "BUILD": "VERIFY",
              "VERIFY": "REVIEW", "REVIEW": "SHIP", "SHIP": "(done)"}
# next phase -> the skill that performs it (DISPATCH.md is the human-facing source;
# this is the machine map the driver uses to pick what to run).
PHASE_SKILL = {"PLAN": "grill", "GATE": "(human decision)", "BUILD": "sprint",
               "VERIFY": "verify", "REVIEW": "review", "SHIP": "ship"}
AUTO_PHASES = {"PLAN", "VERIFY", "REVIEW"}   # reversible — driver may run these
GATE_PHASES = {"GATE", "BUILD", "SHIP"}      # decision / mutation / publish — human
# why a GATE item needs Panda (the standard, docs/driver-autonomy.md)
GATE_REASON = {"GATE": "決策(kill/pivot/scope/approach)",
               "BUILD": "改碼 — 會 land",
               "SHIP": "發佈 / push"}

# --execute may only spawn these reversible skills (the standard's auto set).
SAFE_SKILLS = {"verify", "review", "grill", "plan", "simplify"}
# project slug -> repo dir the headless skill runs in
SLUG_REPO = {
    "murmur": "~/site/apps/murmur", "pandastack": "~/site/skills/pandastack",
    "shawn-trade": "~/site/trading/shawn-trade",
    "equity-research-desk": "~/site/trading/equity-research-desk",
    "hermes-vault": "~/site/hermes-vault",
}
# read-only executor prompt. Mutation is blocked TWO ways: codex `-s read-only`
# (sandbox-enforced) + this instruction. The phase classifier is the third wall
# (BUILD/SHIP never reach here).
EXEC_PROMPT = (
    "You are the pandastack scheduler's headless executor running the {nxt} step for "
    "work-item '{item}' in project '{slug}' (repo: {repo}).\n"
    "Task note: {note}\n"
    "This step is READ-ONLY: investigate / verify / review and report only. Do NOT "
    "edit files, commit, push, publish, send messages, or change any state. If doing "
    "the step properly would need any of those, STOP and report BLOCKED.\n"
    "Reply with EXACTLY one final line:\n"
    "RESULT: <PASS|FAIL|BLOCKED> — <one sentence>"
)


def exec_item(x):
    """Delegate the step to Codex headless (read-only sandbox); advance on PASS.

    Runtime is Codex, not `claude -p`: claude print-mode retires 2026-06-15, and
    Codex runs on Panda's subscription (no per-call $). `-s read-only` enforces
    no-mutation at the sandbox layer."""
    if x["skill"] not in SAFE_SKILLS:
        return {"ran": False, "why": f"skill '{x['skill']}' 不在可逆白名單"}
    repo = SLUG_REPO.get(x["slug"])
    if not repo or not os.path.isdir(os.path.expanduser(repo)):
        return {"ran": False, "why": f"{x['slug']} 無對應 repo"}
    prompt = EXEC_PROMPT.format(nxt=x["next"], item=x["item"], slug=x["slug"],
                                repo=repo, note=x.get("note") or "-")
    rd = os.path.expanduser(repo)
    fd, out_file = tempfile.mkstemp(prefix="psdrive-", suffix=".txt")
    os.close(fd)
    try:
        subprocess.run(["codex", "exec", "-s", "read-only", "-C", rd,
                        "--skip-git-repo-check", "-o", out_file, prompt],
                       capture_output=True, text=True, timeout=1200)
        with open(out_file, encoding="utf-8") as f:
            last = f.read()
    except Exception as e:
        return {"ran": True, "ok": False, "verdict": "ERROR", "summary": str(e)[:120]}
    finally:
        try:
            os.unlink(out_file)
        except OSError:
            pass
    m = re.search(r"RESULT:\s*(PASS|FAIL|BLOCKED)\s*[—-]?\s*(.*)", last)
    verdict = m.group(1) if m else "UNKNOWN"
    summary = ((m.group(2) if m else last).strip())[:160]
    advanced = verdict == "PASS"
    if advanced:
        subprocess.run([sys.executable, STATE, "append", "--slug", x["slug"], "--item",
                        x["item"], "--event", "phase_enter", "--phase", x["next"],
                        "--skill", x["skill"], "--runtime", "codex",
                        "--note", f"auto: {summary}"], check=False)
    return {"ran": True, "ok": advanced, "verdict": verdict, "summary": summary,
            "advanced": advanced}


def slugs():
    return sorted(os.path.basename(os.path.dirname(p))
                  for p in glob.glob(os.path.join(PROJECTS_DIR, "*", "")))


def active_items(slug):
    out = subprocess.run([sys.executable, STATE, "reduce", "--slug", slug, "--json"],
                         capture_output=True, text=True)
    if out.returncode != 0:
        return []
    items = json.loads(out.stdout or "[]")
    return [i for i in items if i.get("status") not in ("shipped", "aborted")]


def classify(item):
    if item.get("status") == "paused":
        return "PAUSED", None, None, "凍結"
    nxt = NEXT_PHASE.get(item.get("phase"), "?")
    if nxt in AUTO_PHASES:
        return "AUTO", nxt, PHASE_SKILL.get(nxt, "?"), None
    if nxt in GATE_PHASES:
        return "GATE", nxt, PHASE_SKILL.get(nxt, "?"), GATE_REASON.get(nxt, "需 Panda")
    return "DONE", nxt, None, None


def build_queue():
    q = {"AUTO": [], "GATE": [], "PAUSED": [], "DONE": []}
    for slug in slugs():
        for item in active_items(slug):
            kind, nxt, skill, reason = classify(item)
            q[kind].append({"slug": slug, "item": item["item"], "phase": item.get("phase"),
                            "next": nxt, "skill": skill, "reason": reason,
                            "note": item.get("note")})
    return q


def main():
    ap = argparse.ArgumentParser(prog="pandastack-drive")
    ap.add_argument("--json", action="store_true")
    ap.add_argument("--run", action="store_true", help="DRY preview: print what --execute would run")
    ap.add_argument("--execute", action="store_true",
                    help="REAL: delegate AUTO skills to Codex headless (read-only), advance on PASS")
    ap.add_argument("--max", type=int, default=1, help="max items to execute per run (default 1)")
    ap.add_argument("--only", help="restrict --execute to one project slug")
    args = ap.parse_args()
    q = build_queue()

    if args.json:
        print(json.dumps(q, ensure_ascii=False, indent=2))
        return 0

    def line(x):
        return f"  {x['slug']}/{x['item']:<24} {str(x['phase']):<7}→{str(x['next']):<7} {x['skill'] or ''}"

    print("TODAY'S QUEUE — pandastack-drive\n")
    print(f"▶ AUTO (reversible, driver may run):  {len(q['AUTO'])}")
    for x in q["AUTO"]:
        print(line(x))
    print(f"\n⏸ GATE (needs you — decision/mutation/publish):  {len(q['GATE'])}")
    for x in q["GATE"]:
        print(line(x) + f"   ← {x['reason']}")
    if q["PAUSED"]:
        print(f"\n🧊 PAUSED:  {len(q['PAUSED'])}")
        for x in q["PAUSED"]:
            print(f"  {x['slug']}/{x['item']}")

    if args.run:
        print("\n--run (DRY preview):")
        for x in q["AUTO"]:
            ok = x["skill"] in SAFE_SKILLS
            print(f"  {'would run' if ok else 'WOULD GATE'}: {x['skill']} on {x['slug']}/{x['item']}"
                  + ("" if ok else "  (skill not in safe allowlist)"))
        print("  GATE / BUILD / SHIP items are never auto-run; they wait for you.")

    if args.execute:
        print(f"\n--execute (Codex headless, read-only sandbox, max {args.max}):")
        n = 0
        for x in q["AUTO"]:
            if args.only and x["slug"] != args.only:
                continue
            if n >= args.max:
                print("  (max reached — rerun for more)"); break
            print(f"  ▶ {x['slug']}/{x['item']} → codex {x['skill']} …")
            r = exec_item(x)
            n += 1
            if not r["ran"]:
                print(f"    gated: {r['why']}")
            else:
                tag = "→ advanced" if r["advanced"] else "(surfaced, not advanced — needs you)"
                print(f"    {r['verdict']} {tag}: {r['summary']}")
    return 0


if __name__ == "__main__":
    sys.exit(main())
