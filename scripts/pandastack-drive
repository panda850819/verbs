#!/usr/bin/env python3
"""pandastack-drive — the scheduler's daily driver, sourced from Linear (the WBS).

Reads the personal Linear workspace via pandastack-linear-reduce — the single WBS
source of truth (docs/linear-contract.md) — and, for each dispatchable issue,
decides the next step and classifies it:

  AUTO  — next phase is reversible analysis (PLAN / VERIFY / REVIEW). The driver
          runs it headless (Codex, read-only sandbox) and PROPOSES the advance.
  GATE  — next phase needs a human: GATE (decision), BUILD (writes code), SHIP
          (publishes); or the issue itself sits in the hard human-gate state.
  BLOCKED — waiting on a non-terminal blocker. Shown, never run.

Linear is the single source of truth: the driver NEVER writes Linear/WBS state.
--execute may write bounded local executor retry metadata; on PASS it prints the
one human-invoked Linear write (pandastack-linear-advance). reversible ->
propose; decision / mutation / publish -> human gate (docs/driver-autonomy.md).

  pandastack-drive                 # surface today's queue (read-only)
  pandastack-drive --json
  pandastack-drive --execute       # run AUTO skills on Codex (read-only), propose advance
"""
import argparse
import contextlib
import fcntl
import hashlib
import json
import os
import re
import shutil
import subprocess
import sys
import tempfile
import time

HERE = os.path.dirname(os.path.abspath(__file__))
sys.path.insert(0, HERE)
import pslib  # shared lifecycle / readiness (single source, review finding K)

REDUCE = os.path.join(HERE, "pandastack-linear-reduce")
AGENT_WORKER = os.path.join(HERE, "agent-worker")
SECRETS = os.path.expanduser("~/.config/pandastack/secrets.env")

# Driver-side phase maps (the lifecycle state<->phase + NEXT_PHASE live in pslib).
PHASE_STATE = {"PLAN": "Planning", "GATE": "Needs Decision", "BUILD": "Building",
               "VERIFY": "Verifying", "REVIEW": "In Review", "SHIP": "Done"}
PHASE_SKILL = {"PLAN": "grill", "GATE": "(human decision)", "BUILD": "sprint",
               "VERIFY": "verify", "REVIEW": "review", "SHIP": "ship"}
AUTO_PHASES = {"PLAN", "VERIFY", "REVIEW"}   # reversible — driver may run these
GATE_PHASES = {"GATE", "BUILD", "SHIP"}      # decision / mutation / publish — human
GATE_REASON = {"GATE": "決策(kill/pivot/scope/approach)", "BUILD": "改碼 — 會 land",
               "SHIP": "發佈 / push"}

# --execute may only spawn these reversible skills (the standard's auto set).
SAFE_SKILLS = {"verify", "review", "grill", "plan", "simplify"}
# Linear project name -> repo dir the headless skill runs in.
PROJECT_REPO = {
    "murmur": "~/site/apps/murmur", "pandastack": "~/site/skills/pandastack",
    "shawn-trade": "~/site/trading/shawn-trade",
    "equity-research-desk": "~/site/trading/equity-research-desk",
    "hermes-vault": "~/site/hermes-vault",
}
# read-only executor prompt. Mutation is blocked THREE ways: the phase classifier
# (BUILD/SHIP never reach here) + codex `-s read-only` (sandbox-enforced) + this
# instruction. The driver itself writes nothing — Linear stays the single truth.
EXEC_PROMPT = (
    "You are the pandastack scheduler's headless executor running the {nxt} step for "
    "Linear issue {item} (project '{project}', repo: {repo}).\n"
    "Issue: {note}\n"
    "This step is READ-ONLY: investigate / verify / review and report only. Do NOT "
    "edit files, commit, push, publish, send messages, or change any state. If doing "
    "the step properly would need any of those, STOP and report BLOCKED.\n"
    "Reply with EXACTLY one final line:\n"
    "RESULT: <PASS|FAIL|BLOCKED> — <one sentence>"
)

BUILD_PROMPT = (
    "You are the pandastack scheduler's headless BUILD executor for Linear issue "
    "{item} (project '{project}'). You are in an ISOLATED git worktree at {wt} on "
    "branch {branch}; the live working tree is untouched.\n"
    "Work-order:\n{desc}\n\n"
    "Implement the work-order in THIS worktree and self-verify it against the issue's "
    "```acceptance``` check. Do NOT commit — leave the files in the worktree; the driver "
    "commits. Remove any scratch / temp files you created so only intended changes remain. "
    "Hard rules: do NOT push, merge, open a PR, touch any path outside this worktree, or "
    "call external services — SHIP stays a human gate. If the acceptance check cannot "
    "pass, STOP and report FAIL.\n"
    "Reply with EXACTLY one final line:\n"
    "RESULT: <PASS|FAIL|BLOCKED> — <one sentence>"
)

# Test seams (PSDRIVE_FIXTURE / PSDRIVE_BUILD_STUB) are honored ONLY under PSDRIVE_TEST=1,
# so a stray env export can never divert or stub a real run (review finding L).
TEST_MODE = os.environ.get("PSDRIVE_TEST") == "1"


def positive_int_env(name, default):
    try:
        value = int(os.environ.get(name, str(default)))
    except ValueError:
        return default
    return value if value > 0 else default


RETRY_BASE_MS = positive_int_env("PSDRIVE_RETRY_BASE_MS", 10000)
RETRY_CAP_MS = max(RETRY_BASE_MS, positive_int_env("PSDRIVE_RETRY_CAP_MS", 300000))
RETRY_MAX_ATTEMPTS = positive_int_env("PSDRIVE_RETRY_MAX_ATTEMPTS", 3)
# Drop a retry record this long after its last update so the store cannot grow
# unbounded with orphans from advanced / edited / abandoned issues (30 days).
RETRY_TTL_MS = positive_int_env("PSDRIVE_RETRY_TTL_MS", 30 * 24 * 60 * 60 * 1000)


def source_fingerprint(issue):
    """Material source revision for clearing stale retry gates after issue edits.

    Fingerprints only the work-order-material fields, NOT Linear's updated_at: a
    label tweak, sub-issue, or (once the linkback loop is wired) an appended ledger
    comment bumps updated_at without changing the work order, and must NOT silently
    reset a backoff/exhaustion gate. A real edit to title/description/state/priority/
    labels still rotates the fingerprint and re-queues the item."""
    material = {k: issue.get(k) for k in ("title", "description", "state", "priority", "labels")}
    raw = json.dumps(material, ensure_ascii=False, sort_keys=True)
    return "sha256:" + hashlib.sha256(raw.encode("utf-8")).hexdigest()[:16]


def retry_state_path():
    """Append-adjacent retry state for the stateless-per-tick driver.

    Linear stays the WBS source of truth. This file only remembers failed executor
    attempts between ticks so a flaky run gets bounded backoff instead of immediate
    retry-spam or silent one-shot failure. Tests may override it only in PSDRIVE_TEST.
    """
    if TEST_MODE and os.environ.get("PSDRIVE_RETRY_STATE"):
        return os.environ["PSDRIVE_RETRY_STATE"]
    root = os.environ.get("PANDASTACK_STATE_HOME", os.path.expanduser("~/.pandastack"))
    return os.path.join(root, "projects", "_driver", "retry.json")


def now_ms():
    if TEST_MODE and os.environ.get("PSDRIVE_NOW_MS"):
        return int(os.environ["PSDRIVE_NOW_MS"])
    return int(time.time() * 1000)


@contextlib.contextmanager
def retry_lock():
    """Serialize the retry-state read-modify-write so an interactive --execute that
    overlaps the launchd tick cannot drop an attempt increment or a PASS-clear (the
    per-file os.replace is atomic, but the load->mutate->save sequence is not)."""
    p = retry_state_path()
    os.makedirs(os.path.dirname(p), exist_ok=True)
    f = open(p + ".lock", "w")
    try:
        fcntl.flock(f.fileno(), fcntl.LOCK_EX)
        yield
    finally:
        fcntl.flock(f.fileno(), fcntl.LOCK_UN)
        f.close()


def dispatch_lock_path():
    if TEST_MODE and os.environ.get("PSDRIVE_DISPATCH_LOCK"):
        return os.environ["PSDRIVE_DISPATCH_LOCK"]
    root = os.environ.get("PANDASTACK_STATE_HOME", os.path.expanduser("~/.pandastack"))
    return os.path.join(root, "projects", "_driver", "dispatch.lock")


def acquire_dispatch_lock():
    """Whole-loop dispatch lock (review C1). The branch-exists guard before
    `git worktree add -b psdrive/<ISSUE>` is check-then-act: an interactive --execute
    overlapping the launchd tick are two processes (launchd's single-instance guarantee
    does NOT cover a hand-run driver), so both could pass the check and race the worktree
    add for one issue. A non-blocking exclusive flock makes dispatch single-writer; a
    second concurrent driver yields cleanly instead of half-building. Returns the held
    file handle — keep the reference so the fd (hence the lock) lives for the whole loop;
    the OS releases it on process exit, matching the stateless-per-tick model — or None if
    another driver already holds it. Read-only views (--json / queue) never call this."""
    p = dispatch_lock_path()
    os.makedirs(os.path.dirname(p), exist_ok=True)
    f = open(p, "w")
    try:
        fcntl.flock(f.fileno(), fcntl.LOCK_EX | fcntl.LOCK_NB)
    except OSError:
        f.close()
        return None
    return f


def iso_ms(ms):
    return time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime(ms / 1000))


def retry_key(x):
    return ":".join([str(x.get("id")), str(x.get("project") or ""), str(x.get("next") or "")])


def load_retry_state():
    p = retry_state_path()
    if not os.path.exists(p):
        return {}
    try:
        with open(p, encoding="utf-8") as f:
            data = json.load(f)
        return data if isinstance(data, dict) else {}
    except (OSError, json.JSONDecodeError):
        return {}


def save_retry_state(state):
    cutoff = now_ms() - RETRY_TTL_MS
    state = {k: v for k, v in state.items()
             if isinstance(v, dict) and int(v.get("updated_ms") or 0) >= cutoff}
    p = retry_state_path()
    os.makedirs(os.path.dirname(p), exist_ok=True)
    fd, tmp = tempfile.mkstemp(prefix="retry-", suffix=".json", dir=os.path.dirname(p))
    try:
        with os.fdopen(fd, "w", encoding="utf-8") as f:
            json.dump(state, f, ensure_ascii=False, indent=2, sort_keys=True)
            f.write("\n")
        os.replace(tmp, p)
    finally:
        try:
            os.unlink(tmp)
        except OSError:
            pass


def retry_gate(x):
    state = load_retry_state()
    key = retry_key(x)
    rec = state.get(key)
    if not rec:
        return None
    if rec.get("source_rev") != (x.get("source_rev") or ""):
        return None
    if rec.get("blocked"):
        return "executor reported BLOCKED — manual review needed"
    if rec.get("exhausted"):
        return f"retry exhausted after {rec.get('attempts', 0)} attempts — manual review needed"
    wait_until = int(rec.get("next_allowed_ms") or 0)
    remaining = wait_until - now_ms()
    if remaining > 0:
        return (f"backoff until {iso_ms(wait_until)} "
                f"(attempts={rec.get('attempts', 0)}, wait_ms={remaining})")
    return None


def record_retry(x, result):
    """Update bounded retry state after one executor attempt.

    PASS clears the item's retry record. FAIL/ERROR/UNKNOWN schedule exponential
    backoff until RETRY_MAX_ATTEMPTS, then stop. BLOCKED becomes a durable
    manual-review gate until the Linear/source issue changes. The whole
    read-modify-write runs under retry_lock so an overlapping tick cannot race.
    """
    with retry_lock():
        return _record_retry_locked(x, result)


def _record_retry_locked(x, result):
    key = retry_key(x)
    state = load_retry_state()
    # An edited issue rotates source_rev: retry_gate already ignores the stale gate,
    # so the attempt counter must restart here too — otherwise the first post-edit
    # failure inherits the old (possibly exhausted) count and re-exhausts at once.
    existing = state.get(key)
    if existing and existing.get("source_rev") != (x.get("source_rev") or ""):
        state.pop(key, None)
    verdict = result.get("verdict")
    if result.get("ok"):
        if key in state:
            del state[key]
            save_retry_state(state)
            return "retry state cleared after PASS"
        return None
    if verdict == "BLOCKED":
        old = state.get(key, {})
        state[key] = {"id": x.get("id"), "project": x.get("project"),
                      "next": x.get("next"), "attempts": int(old.get("attempts") or 0),
                      "last_verdict": verdict,
                      "last_summary": (result.get("summary") or "")[:200],
                      "updated_ms": now_ms(), "source_rev": x.get("source_rev") or "",
                      "blocked": True, "exhausted": True}
        save_retry_state(state)
        return "executor reported BLOCKED — manual review needed (no retry scheduled)"
    if verdict not in {"FAIL", "ERROR", "UNKNOWN"}:
        return None
    old = state.get(key, {})
    attempts = int(old.get("attempts") or 0) + 1
    rec = {"id": x.get("id"), "project": x.get("project"), "next": x.get("next"),
           "attempts": attempts, "last_verdict": verdict,
           "last_summary": (result.get("summary") or "")[:200], "updated_ms": now_ms(),
           "source_rev": x.get("source_rev") or ""}
    if attempts >= RETRY_MAX_ATTEMPTS:
        rec["exhausted"] = True
        state[key] = rec
        save_retry_state(state)
        return f"retry exhausted after {attempts} attempts — manual review needed"
    delay = min(RETRY_BASE_MS * (2 ** (attempts - 1)), RETRY_CAP_MS)
    rec["next_allowed_ms"] = now_ms() + delay
    state[key] = rec
    save_retry_state(state)
    return (f"retry scheduled: attempt {attempts + 1}/{RETRY_MAX_ATTEMPTS} "
            f"after {delay}ms at {iso_ms(rec['next_allowed_ms'])}")


def load_secrets():
    """Load LINEAR_API_KEY (and friends) so the reduce subprocess can reach Linear."""
    if not os.path.isfile(SECRETS):
        return
    for ln in open(SECRETS, encoding="utf-8"):
        ln = ln.strip()
        if ln.startswith("export "):
            ln = ln[7:]
        if "=" in ln and not ln.startswith("#"):
            k, v = ln.split("=", 1)
            os.environ.setdefault(k.strip(), v.strip().strip('"').strip("'"))


def worker_env():
    keep_exact = {
        "PATH", "HOME", "USER", "LOGNAME", "SHELL", "TMPDIR", "TEMP", "TMP",
        "LANG", "LC_ALL", "LC_CTYPE", "TERM", "COLORTERM", "NO_COLOR",
        "SSL_CERT_FILE", "SSL_CERT_DIR",
    }
    keep_prefixes = ("LC_",)
    return {
        key: value for key, value in os.environ.items()
        if key in keep_exact or any(key.startswith(prefix) for prefix in keep_prefixes)
    }


def git_env():
    env = os.environ.copy()
    env.update({
        "GIT_CONFIG_NOSYSTEM": "1",
        "GIT_CONFIG_GLOBAL": os.devnull,
        "GIT_CONFIG_SYSTEM": os.devnull,
    })
    return env


def trusted_git_dir(worktree):
    cp = subprocess.run(["git", "-C", worktree, "rev-parse", "--git-dir"],
                        capture_output=True, text=True, env=git_env())
    if cp.returncode != 0:
        return None
    git_dir = cp.stdout.strip()
    if not os.path.isabs(git_dir):
        git_dir = os.path.join(worktree, git_dir)
    return os.path.realpath(git_dir)


def safe_git(worktree, git_dir, args):
    return subprocess.run(["git", "--git-dir", git_dir, "--work-tree", worktree,
                           "-c", "core.fsmonitor=false",
                           "-c", "core.hooksPath=/dev/null", *args],
                          capture_output=True, text=True, env=git_env())


# --- T03 blast×verifiability router + integration auto-merge (boundary #1) -----------
# auto-merge ships gated OFF; it only runs under --merge-auto (which requires
# --build-auto --only), and only for a low-blast, machine-lane, host-verified-green
# build. main is NEVER pushed or merged here — the loop owns integration; integration→
# main stays a human promote (T05a). The whole step is ratchet-unlocked, not day-1.

def blast_policy_path():
    if TEST_MODE and os.environ.get("PSDRIVE_BLAST_POLICY"):
        return os.environ["PSDRIVE_BLAST_POLICY"]
    return os.path.join(os.path.dirname(os.path.dirname(os.path.abspath(__file__))),
                        "config", "high-blast-paths")


def load_blast_policy():
    """High-blast glob patterns, or None if the policy file is unreadable (→ caller
    treats every change as high-blast: default-deny)."""
    try:
        pats = []
        for ln in open(blast_policy_path(), encoding="utf-8"):
            ln = ln.strip()
            if ln and not ln.startswith("#"):
                pats.append(ln)
        return pats
    except OSError:
        return None


def _glob_to_re(pat):
    """Translate a path glob to an anchored regex: ** spans '/', * stays within a
    segment, ? is one non-separator char."""
    out, i = [], 0
    while i < len(pat):
        if pat[i] == "*":
            if pat[i:i + 2] == "**":
                out.append(".*"); i += 2; continue
            out.append("[^/]*"); i += 1; continue
        if pat[i] == "?":
            out.append("[^/]"); i += 1; continue
        out.append(re.escape(pat[i])); i += 1
    return re.compile("^" + "".join(out) + "$")


def path_is_high_blast(path, patterns):
    for pat in patterns:
        rx = _glob_to_re(pat)
        # also try a leading-slash variant so `**/X/**` catches a top-level X/ too
        if rx.match(path) or rx.match("/" + path):
            return True
    return False


def classify_blast(changed_paths, patterns):
    """Default-deny: 'high' unless the diff is readable, non-empty, and NO changed path
    matches any high-blast glob. Returns (blast, reason)."""
    if patterns is None:
        return "high", "blast policy unreadable (default-deny)"
    if not changed_paths:
        return "high", "empty or unreadable diff (default-deny)"
    for p in changed_paths:
        if path_is_high_blast(p, patterns):
            return "high", f"changed path matches high-blast policy: {p}"
    return "low", "all changed paths outside high-blast policy"


def git_diff_paths(rd, base, branch):
    """Every path the branch changes vs base from the REAL git diff (not the model's
    self-report): rename OLD and NEW both, deletions included. Empty on any git error
    → classify_blast denies (high-blast)."""
    cp = subprocess.run(["git", "-C", rd, "diff", "--name-status", "-M",
                         f"{base}...{branch}"], capture_output=True, text=True, env=git_env())
    if cp.returncode != 0:
        return []
    paths = []
    for ln in cp.stdout.splitlines():
        parts = ln.split("\t")
        if not parts or not parts[0]:
            continue
        if parts[0].startswith("R") and len(parts) >= 3:
            paths.extend([parts[1], parts[2]])      # rename: old AND new
        elif len(parts) >= 2:
            paths.append(parts[1])                  # add / modify / delete
    return paths


def merge_to_integration(rd, branch, base):
    """Merge `branch` into the integration branch in an ISOLATED worktree so the live
    tree is untouched and main is never checked out. Create integration from `base` if
    absent. A non-clean merge is aborted (never a half-merge) and surfaced as a gate.
    Nothing is ever pushed. Returns {merged: bool, ...}."""
    integ = "psdrive/integration"
    itmp = tempfile.mkdtemp(prefix="psdrive-integ-")
    try:
        # prune BEFORE the add: a tick SIGKILLed between worktree-add and the finally
        # leaves psdrive/integration registered to a now-gone dir, and every later add
        # then fails — silently wedging ALL future auto-merges until a human prunes by
        # hand. Pruning first makes the unattended loop self-heal from a crashed tick.
        subprocess.run(["git", "-C", rd, "worktree", "prune"], capture_output=True, text=True, env=git_env())
        exists = subprocess.run(["git", "-C", rd, "rev-parse", "--verify", "--quiet", integ],
                                capture_output=True, text=True).returncode == 0
        add = (["git", "-C", rd, "worktree", "add", itmp, integ] if exists
               else ["git", "-C", rd, "worktree", "add", "-b", integ, itmp, base])
        a = subprocess.run(add, capture_output=True, text=True, env=git_env())
        if a.returncode != 0:
            return {"merged": False, "gate": True,
                    "reason": "integration worktree add failed: " + (a.stderr or "").strip()[:140]}
        cur = subprocess.run(["git", "-C", itmp, "rev-parse", "--abbrev-ref", "HEAD"],
                             capture_output=True, text=True, env=git_env()).stdout.strip()
        if cur != integ:                            # never-main guard: refuse anything but integration
            return {"merged": False, "gate": True,
                    "reason": f"refusing merge: integration worktree on '{cur}', not {integ}"}
        mg = subprocess.run(["git", "-C", itmp, "-c", "core.hooksPath=/dev/null",
                             "merge", "--no-ff", "--no-edit", branch],
                            capture_output=True, text=True, env=git_env())
        if mg.returncode != 0:
            subprocess.run(["git", "-C", itmp, "merge", "--abort"],
                           capture_output=True, text=True, env=git_env())
            return {"merged": False, "gate": True,
                    "reason": "merge not clean — aborted, no half-merge: "
                              + (mg.stdout or mg.stderr or "").strip()[:140]}
        sha = subprocess.run(["git", "-C", itmp, "rev-parse", "HEAD"],
                             capture_output=True, text=True, env=git_env()).stdout.strip()
        return {"merged": True, "integration": integ, "sha": sha}
    finally:
        subprocess.run(["git", "-C", rd, "worktree", "remove", "--force", itmp],
                       capture_output=True, text=True, env=git_env())
        subprocess.run(["git", "-C", rd, "worktree", "prune"], capture_output=True, text=True, env=git_env())
        shutil.rmtree(itmp, ignore_errors=True)


def linear_reduce():
    """The WBS read: pandastack-linear-reduce over the whole workspace (single source)."""
    fixture = os.environ.get("PSDRIVE_FIXTURE") if TEST_MODE else None  # test seam (guarded)
    src = ["--source", "fixture", "--file", fixture] if fixture else ["--source", "linear"]
    out = subprocess.run([sys.executable, REDUCE, *src, "--json"],
                         capture_output=True, text=True)
    if out.returncode != 0:
        sys.exit("linear reduce failed: " + (out.stderr or out.stdout or "").strip())
    return json.loads(out.stdout or "{}")


def worker_job_root():
    root = os.environ.get("PSDRIVE_WORKER_JOB_ROOT")
    if not root:
        root = os.path.join(os.path.expanduser("~/.local/state/pandastack/worker-jobs"))
    os.makedirs(root, mode=0o700, exist_ok=True)
    return root


def safe_slug(s):
    return re.sub(r"[^A-Za-z0-9._-]", "-", str(s or "job"))[:48]


def acceptance_block(desc):
    m = re.search(r"```acceptance\s*\n(.*?)\n```", desc or "", re.S)
    return (m.group(1).strip() + "\n") if m else None


def extract_acceptance(desc):
    return acceptance_block(desc) or "No explicit acceptance block supplied.\n"


def harden_verify(script):
    """Force strict mode on a materialized verify script (review F-B). Without
    `set -euo pipefail`, a real assertion that fails mid-script is masked by a
    trailing success (e.g. `grep -q X` then `echo done` exits 0), so host-verify
    reports a false green. Inject strict mode right after any author shebang."""
    body = script or ""
    if body.lstrip().startswith("#!"):
        first, _, rest = body.partition("\n")
        return f"{first}\nset -euo pipefail\n{rest}"
    return "#!/usr/bin/env bash\nset -euo pipefail\n" + body


def run_worker_job(backend, worktree, prompt, request, spec=None, acceptance=None,
                   verify_script=None, job_name=None, metadata=None, test_options=None):
    """Run one bounded worker job through the repo-local agent-worker protocol.

    pandastack-drive owns queue semantics and phase policy; scripts/agent-worker owns
    backend-specific CLI flags, logs, result parsing, verification, and changed files.
    """
    if not os.path.isfile(AGENT_WORKER):
        return {"ran": True, "ok": False, "verdict": "ERROR",
                "summary": "agent-worker adapter missing"}
    issue = job_name or (metadata or {}).get("issue") or (metadata or {}).get("project") or "job"
    job = tempfile.mkdtemp(prefix=f"psworker-{safe_slug(issue)}-", dir=worker_job_root())
    try:
        os.makedirs(os.path.join(job, "output"), exist_ok=True)
        os.makedirs(os.path.join(job, "logs"), exist_ok=True)
        prompt_path = os.path.join(job, "prompt.md")
        out_path = os.path.join(job, "output", "result.json")
        with open(prompt_path, "w", encoding="utf-8") as f:
            f.write(prompt)
        with open(os.path.join(job, "spec.md"), "w", encoding="utf-8") as f:
            f.write(spec or "# pandastack worker job\n\nGenerated by pandastack-drive.\n")
        with open(os.path.join(job, "acceptance.md"), "w", encoding="utf-8") as f:
            f.write(acceptance or "No explicit acceptance block supplied.\n")
        if verify_script:
            verify_path = os.path.join(job, "verify.sh")
            with open(verify_path, "w", encoding="utf-8") as f:
                f.write(harden_verify(verify_script))   # F-B: force set -euo pipefail
            os.chmod(verify_path, 0o700)
        if metadata:
            with open(os.path.join(job, "metadata.json"), "w", encoding="utf-8") as f:
                json.dump(metadata, f, ensure_ascii=False, indent=2, sort_keys=True)
                f.write("\n")
        if test_options:
            with open(os.path.join(job, "test.json"), "w", encoding="utf-8") as f:
                json.dump(test_options, f, ensure_ascii=False, indent=2, sort_keys=True)
                f.write("\n")
        with open(os.path.join(job, "request.json"), "w", encoding="utf-8") as f:
            json.dump(request, f, ensure_ascii=False, indent=2, sort_keys=True)
            f.write("\n")
        try:
            cp = subprocess.run([sys.executable, AGENT_WORKER, "run",
                                 "--backend", backend,
                                 "--job-dir", job,
                                 "--worktree", worktree,
                                 "--prompt", prompt_path,
                                 "--out", out_path],
                                capture_output=True, text=True,
                                timeout=int(request.get("timeout_seconds") or 1200) + 30,
                                env=worker_env())
        except subprocess.TimeoutExpired as e:
            return {"ran": True, "ok": False, "verdict": "ERROR", "job_dir": job,
                    "summary": "agent-worker timed out: " + str(e)[:120]}
        if cp.returncode != 0:
            return {"ran": True, "ok": False, "verdict": "ERROR", "job_dir": job,
                    "summary": (cp.stderr or cp.stdout or "agent-worker failed").strip()[:160]}
        with open(out_path, encoding="utf-8") as f:
            result = json.load(f)
        verdict = result.get("status") or "UNKNOWN"
        return {"ran": True, "ok": verdict == "PASS", "verdict": verdict,
                "summary": (result.get("summary") or "")[:160],
                "changed_files": result.get("changed_files") or [],
                "verification": result.get("verification") or {},
                "artifacts": result.get("artifacts") or {},
                "worker": result}
    except Exception as e:
        return {"ran": True, "ok": False, "verdict": "ERROR", "job_dir": job,
                "summary": str(e)[:160]}


def entry(issue, nxt, skill, reason):
    return {"id": issue["identifier"], "project": issue.get("project"),
            "title": issue.get("title", ""), "state": issue.get("state"),
            "phase": pslib.phase_of(issue.get("state")) or "?",
            "next": nxt, "skill": skill, "reason": reason,
            "to_state": PHASE_STATE.get(nxt), "repo": PROJECT_REPO.get(issue.get("project") or ""),
            "source_rev": source_fingerprint(issue)}


def enqueue_auto_or_retry_gate(q, e):
    gate = retry_gate(e)
    if gate:
        e["reason"] = "retry-gate (" + gate + ")"
        q["GATE"].append(e)
    else:
        q["AUTO"].append(e)


def build_queue(build_auto=False, only=None):
    red = linear_reduce()
    q = {"AUTO": [], "GATE": [], "BLOCKED": []}
    # reduce already split off the hard human-gate + readiness + blocked issues.
    for i in red.get("gated", []):
        if i.get("reason") == "needs-spec":
            reason = "needs-spec (" + (i.get("gap") or "underspecified") + ")"
        else:
            reason = "needs-human (硬 gate)"
        q["GATE"].append(entry(i, None, "(human decision)", reason))
    for i in red.get("blocked", []):
        q["BLOCKED"].append(entry(i, None, None, "blocked_by"))
    # dispatchable: classify by whether the NEXT phase is reversible (AUTO) or a gate.
    for i in red.get("dispatchable", []):
        phase = pslib.phase_of(i.get("state")) or "?"
        # BUILD autonomy (default OFF, --only scoped): a Building issue routes to an
        # auto-build instead of assuming code was already written. Without the flag,
        # behavior is unchanged (Building -> auto-verify).
        if build_auto and phase == "BUILD" and (only is None or i.get("project") == only):
            if pslib.work_order_complete(i.get("description")):
                e = entry(i, "BUILD", PHASE_SKILL["BUILD"], None)
                e["build"] = True
                e["to_state"] = PHASE_STATE["VERIFY"]   # build done -> propose Verifying
                e["desc"] = i.get("description", "")     # work-order for the build prompt
                enqueue_auto_or_retry_gate(q, e)
            else:
                q["GATE"].append(entry(i, "BUILD", PHASE_SKILL["BUILD"],
                                       "needs-spec (work-order/acceptance 不完整)"))
            continue
        nxt = pslib.NEXT_PHASE.get(phase, "?")
        skill = PHASE_SKILL.get(nxt, "?")
        if nxt in AUTO_PHASES:
            enqueue_auto_or_retry_gate(q, entry(i, nxt, skill, None))
        else:
            q["GATE"].append(entry(i, nxt, skill, GATE_REASON.get(nxt, "需 Panda")))
    return q


def exec_item(x):
    """Run the reversible step through agent-worker; propose the Linear advance."""
    if x["skill"] not in SAFE_SKILLS:
        return {"ran": False, "why": f"skill '{x['skill']}' 不在可逆白名單"}
    repo = x.get("repo")
    if not repo or not os.path.isdir(os.path.expanduser(repo)):
        return {"ran": False, "why": f"{x['id']} ({x.get('project')}) 無對應 repo"}
    prompt = EXEC_PROMPT.format(nxt=x["next"], item=x["id"], project=x.get("project"),
                                repo=repo, note=x.get("title") or "-")
    rd = os.path.expanduser(repo)
    spec = "# pandastack worker job\n\n" \
           f"Issue: {x['id']}\nProject: {x.get('project')}\nPhase: {x['next']}\nMode: read-only\n"
    acceptance = "Worker must return exactly one final `RESULT: PASS|FAIL|BLOCKED — summary` line.\n"
    r = run_worker_job("codex", rd, prompt,
                       {"mode": "read-only", "network_access": False,
                        "timeout_seconds": 1200},
                       spec=spec, acceptance=acceptance, job_name=x["id"],
                       metadata={"issue": x["id"], "project": x.get("project"),
                                 "phase": x["next"]})
    passed = r.get("verdict") == "PASS"
    # Linear is the single truth; the driver NEVER writes it. On PASS, surface the
    # one human-invoked advance (pandastack-linear-advance) — do not auto-write.
    if passed and x.get("to_state"):
        r["advance"] = f'pandastack-linear-advance --issue {x["id"]} --to "{x["to_state"]}"'
    return r


def evidence_body(wr, acceptance, staged):
    """A commit-message body that puts the host-verify evidence inline (T04), so a human's
    30-second pre-graduation stamp is honest: the verify result + command, the acceptance
    checked, the verify-output tail, and the changed-file count — all from the worker result."""
    v = wr.get("verification") or {}
    lines = ["[auto-build evidence]"]
    if v.get("ran"):
        cmd = v.get("command")
        lines.append(f"host-verify: {'PASS' if v.get('ok') else 'FAIL'}" + (f"  ({cmd})" if cmd else ""))
        tail = (v.get("stdout_tail") or "").strip()
        if tail:
            lines.append("verify-output (tail):")
            lines += ["  " + ln for ln in tail.splitlines()[-6:]]
    else:
        lines.append("host-verify: not run")
    acc = (acceptance or "").strip()
    if acc and not acc.startswith("No explicit acceptance"):
        lines.append("acceptance:")
        lines += ["  " + ln for ln in acc.splitlines()[:8]]
    n = len([s for s in (staged or "").splitlines() if s.strip()])
    lines.append(f"changed files: {n}")
    return "\n".join(lines)


def exec_build(x, merge_auto=False):
    """Run the BUILD skill in an ISOLATED git worktree, sandboxed to `workspace-write`
    with network pinned OFF (codex physically cannot push, regardless of ~/.codex
    config). The live working tree is never touched. The model only writes files; the
    DRIVER commits (the worktree .git is outside the sandbox) with hooks disabled, so a
    codex-written tracked hook cannot execute outside the sandbox. PASS keeps the branch
    for a human PR; FAIL discards worktree + branch. SHIP stays a human gate. A kept PASS
    branch is left alone on later ticks (not rebuilt). Test seam: PSDRIVE_BUILD_STUB
    (under PSDRIVE_TEST) skips codex."""
    repo = x.get("repo")
    if not repo or not os.path.isdir(os.path.expanduser(repo)):
        return {"ran": False, "why": f"{x['id']} ({x.get('project')}) 無對應 repo"}
    rd = os.path.expanduser(repo)
    branch = "psdrive/" + re.sub(r"[^A-Za-z0-9._-]", "-", str(x["id"]))
    # a kept PASS branch means this issue was already built and is awaiting a human PR /
    # advance — do NOT rebuild it every tick (review finding C). Surface, don't retry.
    if subprocess.run(["git", "-C", rd, "rev-parse", "--verify", "--quiet", branch],
                      capture_output=True, text=True).returncode == 0:
        return {"ran": False, "why": f"branch {branch} 已存在(已 build,待 review/advance)"}
    # the commit the branch forks from = the real diff base for blast classification (T03).
    base_sha = subprocess.run(["git", "-C", rd, "rev-parse", "HEAD"],
                              capture_output=True, text=True).stdout.strip()
    wt = tempfile.mkdtemp(prefix=f"psdrive-wt-{x['id']}-")
    made_wt = False
    keep_branch = False
    try:
        r = subprocess.run(["git", "-C", rd, "worktree", "add", "-b", branch, wt],
                           capture_output=True, text=True)
        if r.returncode != 0:
            return {"ran": True, "ok": False, "verdict": "ERROR",
                    "summary": "worktree add failed: " + (r.stderr or "").strip()[:140]}
        made_wt = True
        git_dir = trusted_git_dir(wt)
        if not git_dir:
            return {"ran": True, "ok": False, "verdict": "ERROR",
                    "summary": "worktree git-dir unavailable"}
        prompt = BUILD_PROMPT.format(item=x["id"], project=x.get("project"), wt=wt,
                                     branch=branch, desc=x.get("desc") or x.get("title") or "-")
        backend = "codex"
        desc = x.get("desc") or ""
        acc = extract_acceptance(desc)
        verify_script = acceptance_block(desc)
        request = {"mode": "workspace-write", "network_access": False,
                   "timeout_seconds": 1800}
        if verify_script:
            request["allow_host_verify"] = True
            # F-A mutation sentinel (PRO-41): a discriminating acceptance must FAIL on
            # the pre-build tree — the change is not there yet. If it already passes on
            # unchanged code it is tautological (true / exit 0 / echo) OR it targets an
            # absolute path and tests the live repo, not this worktree. Either way a
            # post-build PASS proves nothing, so refuse to auto-build and route to a human
            # (BLOCKED). Fail-safe: only ever demotes, never auto-passes. Auto-build
            # acceptances must therefore be worktree-relative. A refactor whose tests pass
            # pre-build trips this too — accepted: it routes to a human, never a false green.
            try:
                pre = subprocess.run(["bash", "-c", harden_verify(verify_script)],
                                     cwd=wt, capture_output=True, text=True, timeout=600)
                pre_passed = pre.returncode == 0
            except subprocess.TimeoutExpired:
                pre_passed = True   # a hang on unchanged code is not a discriminating check
            if pre_passed:
                return {"ran": True, "ok": False, "verdict": "BLOCKED",
                        "summary": "acceptance passed on pre-build HEAD — tautological, or it "
                                   "targets an absolute path (tests the live repo, not this "
                                   "change). Auto-build acceptances must be worktree-relative; "
                                   "give a discriminating check or verify by hand."}
        stub = os.environ.get("PSDRIVE_BUILD_STUB") if TEST_MODE else None  # test seam (guarded)
        test_options = None
        if stub:
            backend = "test"
            test_options = {"test_status": stub.upper(), "test_summary": "stubbed"}
            if stub.upper() == "PASS":
                # test seam: let a blast-router test make the stubbed build touch a
                # policy-matching path (e.g. migrations/x.sql) to exercise high-blast.
                stub_file = os.environ.get("PSDRIVE_BUILD_STUB_FILE") or ".psdrive-stub"
                test_options.update({"write_file": stub_file,
                                     "write_text": "stub build artifact\n"})
        spec = "# pandastack BUILD worker job\n\n" \
               f"Issue: {x['id']}\nProject: {x.get('project')}\nBranch: {branch}\nWorktree: {wt}\n"
        wr = run_worker_job(backend, wt, prompt, request,
                            spec=spec, acceptance=acc, verify_script=verify_script,
                            job_name=x["id"],
                            metadata={"issue": x["id"], "project": x.get("project"),
                                      "phase": "BUILD", "branch": branch},
                            test_options=test_options)
        verdict, summary = wr.get("verdict"), wr.get("summary")
        passed = verdict == "PASS"
        committed = False
        staged = ""
        if passed:
            # log the staged file list so the human PR step can catch stray/sensitive
            # paths (review finding E); commit with hooks DISABLED (--no-verify + empty
            # hooksPath) so a codex-written tracked hook can't run unsandboxed (finding B).
            staged = safe_git(wt, git_dir, ["status", "--porcelain"]).stdout.strip()
            safe_git(wt, git_dir, ["add", "-A"])
            cm = safe_git(wt, git_dir, ["commit", "--no-verify",
                                        "-m", f"feat({x['id']}): {x.get('title') or 'auto-build'}",
                                        "-m", evidence_body(wr, acc, staged)])  # T04: inline verify evidence
            committed = cm.returncode == 0
        if passed and committed:
            keep_branch = True
            verify = wr.get("verification") or {}
            result = {"ran": True, "ok": True, "verdict": "PASS", "summary": summary,
                      "branch": branch, "staged": staged, "verification": verify,
                      "worker": wr,
                      "artifacts": wr.get("artifacts") or {},
                      "verify_cmd": (verify_script or "").strip()[:200] or None,
                      "pr_hint": f"review local branch {branch} and open a PR (driver never pushes)",
                      "advance": f'pandastack-linear-advance --issue {x["id"]} --to "{x.get("to_state", "Verifying")}"'}
            # T03 router (gated OFF unless --merge-auto). Auto-merge ONLY a low-blast,
            # machine-lane (host-verify actually ran), host-verified-green build — and
            # only into integration, never main. Everything else keeps the branch for a
            # human PR (unchanged rung-0 behavior). read-only AUTO-VERIFY never reaches
            # here, so a model PASS without a real host-verify (verify.ran False) can never
            # auto-merge (F-M).
            blast, why = classify_blast(git_diff_paths(rd, base_sha, branch), load_blast_policy())
            result["blast"] = blast
            machine_green = bool(verify.get("ran")) and verify.get("ok") is True
            if merge_auto and blast == "low" and machine_green:
                m = merge_to_integration(rd, branch, base_sha)
                if m.get("merged"):
                    result["merged"] = m["integration"]
                    result["merged_sha"] = m.get("sha")   # the merge commit, to correlate human-reverts (trust streak)
                    result["pr_hint"] = (f"auto-merged {branch} → {m['integration']} "
                                         f"(low-blast, host-verified). integration→main stays a human promote.")
                else:
                    # non-clean / refused → never half-merged; surface as a gate, keep branch.
                    result["gate"] = True
                    result["advance"] = None
                    result["pr_hint"] = "integration merge not clean — aborted (no half-merge), gated: " + (m.get("reason") or "")
            elif merge_auto:
                result["merge_skip"] = (why if blast == "high"
                                        else "host-verify not green (machine-lane gate, F-M)")
                result["pr_hint"] = f"not auto-merged ({result['merge_skip']}) — review {branch} and open a PR."
            return result
        if passed and not committed:
            return {"ran": True, "ok": False, "verdict": "FAIL",
                    "summary": "acceptance passed but no changes to commit: " + (cm.stderr or cm.stdout or "").strip()[:120],
                    "verification": wr.get("verification") or {},
                    "worker": wr, "artifacts": wr.get("artifacts") or {}}
        return {"ran": True, "ok": False, "verdict": verdict, "summary": summary,
                "verification": wr.get("verification") or {},
                "worker": wr, "artifacts": wr.get("artifacts") or {}}
    finally:
        # single cleanup path (review finding I): always remove the worktree dir; delete
        # the branch unless a committed PASS is keeping it. prune handles a stuck remove.
        if made_wt:
            subprocess.run(["git", "-C", rd, "worktree", "remove", "--force", wt],
                           capture_output=True, text=True)
            subprocess.run(["git", "-C", rd, "worktree", "prune"], capture_output=True, text=True)
        shutil.rmtree(wt, ignore_errors=True)
        if not keep_branch:
            subprocess.run(["git", "-C", rd, "branch", "-D", branch], capture_output=True, text=True)


def ledger_record(x, r):
    """Normalize one executed item into a structured ledger record (LG, F-K/F-L).

    The fields that make 'zero fake-green' git-greppable: `verify_required` (does
    this advance need a real host-verify — True for BUILD/merge, False for a
    read-only AUTO advisory step, F-M) and `verify_ran` (did host-verify actually
    run). The success-signal counter-example is one grep:

        verdict == "PASS" AND advance AND verify_required AND NOT verify_ran

    i.e. a PASS that proposed a state advance it was supposed to host-verify, but
    no host-verify ran. In healthy operation that count is 0 (a BUILD-auto issue
    always carries a machine-runnable acceptance, so host-verify always runs; a
    failed host-verify is demoted to FAIL upstream by maybe_apply_verification)."""
    v = (r.get("verification") or {}) if isinstance(r, dict) else {}
    ran = bool(v.get("ran"))
    return {
        "id": x.get("id"),
        "project": x.get("project"),
        "phase": x.get("next"),
        "verdict": r.get("verdict"),
        "summary": (r.get("summary") or "")[:200],
        "advance": (r.get("advance") or None),
        # BUILD lands code → its advance must be host-verified; read-only AUTO is advisory.
        "verify_required": bool(x.get("build")),
        "verify_ran": ran,
        "verify_ok": v.get("ok"),
        # prefer the human-meaningful acceptance text (exec_build attaches it); fall
        # back to the materialized script path the worker actually executed.
        "verify_cmd": r.get("verify_cmd") or v.get("command"),
        "verify_tail": ((v.get("stdout_tail") or v.get("stderr_tail") or "").strip()[-400:]) or None,
        # T03: blast class + the integration branch this merged into (None = PR-only).
        # A merge event must be host-verified, so the merge-scoped fake-green grep is
        # `verdict==PASS AND merged AND verify_required AND NOT verify_ran` → must be 0.
        "blast": r.get("blast"),
        "merged": (r.get("merged") or None),
        "merged_sha": (r.get("merged_sha") or None),
    }


def main():
    ap = argparse.ArgumentParser(prog="pandastack-drive")
    ap.add_argument("--json", action="store_true")
    ap.add_argument("--execute", action="store_true",
                    help="run AUTO skills on Codex headless (read-only); on PASS, propose the Linear advance")
    ap.add_argument("--max", type=int, default=1, help="max items to execute per run (default 1)")
    ap.add_argument("--only", help="restrict --execute to one Linear project")
    ap.add_argument("--build-auto", action="store_true",
                    help="(default OFF) route a build-ready Building issue to auto-build in an isolated worktree; requires --only")
    ap.add_argument("--merge-auto", action="store_true",
                    help="(default OFF, ratchet-gated) auto-merge a low-blast host-verified build into the integration branch (never main); requires --build-auto --only")
    args = ap.parse_args()
    if args.build_auto and not args.only:
        ap.error("--build-auto requires --only <project> (never global)")
    if args.merge_auto and not (args.build_auto and args.only):
        ap.error("--merge-auto requires --build-auto --only (never global; integration auto-merge is ratchet-gated)")
    # Kill-switch: only DISPATCH is suppressed; read-only queue views stay visible
    # so you can still see what is parked while stopped (PRO-36, boundary #12).
    if args.execute and pslib.drive_suppressed():
        print(f"⛔ kill-switch present ({pslib.stop_flag_path()}) — zero dispatch.")
        return 0
    load_secrets()
    q = build_queue(build_auto=args.build_auto, only=args.only)

    if args.json:
        print(json.dumps(q, ensure_ascii=False, indent=2))
        return 0

    def line(x):
        return (f"  {x['id']:<8} {(x.get('project') or '?'):<10} {str(x['state']):<14} "
                f"{str(x['phase']):<6}→{str(x['next'] or '')}")

    print("TODAY'S QUEUE — pandastack-drive (source: Linear)\n")
    print(f"▶ AUTO (reversible — driver runs read-only, proposes advance):  {len(q['AUTO'])}")
    for x in q["AUTO"]:
        print(line(x) + f"  {x['skill'] or ''}")
    print(f"\n⏸ GATE (needs you — decision / mutation / publish):  {len(q['GATE'])}")
    for x in q["GATE"]:
        print(line(x) + f"   ← {x['reason']}")
    if q["BLOCKED"]:
        print(f"\n⛔ BLOCKED:  {len(q['BLOCKED'])}")
        for x in q["BLOCKED"]:
            print(line(x))

    if args.execute:
        # Whole-loop concurrency lock (review C1): make dispatch single-writer so the
        # branch-exists / worktree-add critical section can't be raced by an interactive
        # --execute overlapping the launchd tick. Held for the whole loop (the OS frees it
        # on process exit). The read-only queue above already printed, so a contended tick
        # still shows what is parked — only DISPATCH is skipped (mirrors the kill-switch).
        _dispatch_lock = acquire_dispatch_lock()  # noqa: F841 — ref keeps the fd/lock alive
        if _dispatch_lock is None:
            print("⏸ another pandastack-drive --execute is dispatching — skipping this tick (concurrency lock).")
            return 0
        print(f"\n--execute (Codex headless, sandboxed, max {args.max}):")
        n = 0
        ledger = []
        for x in q["AUTO"]:
            if args.only and x.get("project") != args.only:
                continue
            if n >= args.max:
                print("  (max reached — rerun for more)"); break
            gate = retry_gate(x)
            if gate:
                print(f"  ▶ {x['id']} ({x.get('project')}) → skipped: {gate}")
                continue                      # backoff/exhausted skips do not consume --max
            print(f"  ▶ {x['id']} ({x.get('project')}) → codex {x['skill']} …")
            r = exec_build(x, merge_auto=args.merge_auto) if x.get("build") else exec_item(x)
            if not r["ran"]:
                print(f"    skipped: {r['why']}")
                continue                      # a skip does not consume a --max slot (finding N)
            n += 1
            ledger.append(ledger_record(x, r))
            print(f"    {r['verdict']}: {r['summary']}")
            if r.get("merged"):
                print(f"    → auto-merged into {r['merged']} (blast={r.get('blast')})")
            retry_note = record_retry(x, r)
            if retry_note:
                print(f"    → {retry_note}")
            if r.get("staged"):
                print("    staged:\n      " + r["staged"].replace("\n", "\n      "))
            if r.get("pr_hint"):
                print(f"    → {r['pr_hint']}")
            if r.get("advance"):
                print(f"    → ready to advance (run it yourself): {r['advance']}")
        if n == 0:
            print("  (no AUTO items ran)")
        # Structured ledger handoff (LG, F-K/F-L): one machine-readable line the
        # drive-cron wrapper appends to drive-log.jsonl verbatim, instead of
        # regex-parsing this human stdout. Carries verify_ran/verify_ok/verify_cmd
        # so 'zero fake-green' and the merge streak are git-greppable.
        blob = {"auto": len(q["AUTO"]), "gate": len(q["GATE"]),
                "blocked": len(q["BLOCKED"]), "gate_ids": [g["id"] for g in q["GATE"]],
                "executed": ledger}
        print(pslib.LEDGER_SENTINEL + " " + json.dumps(blob, ensure_ascii=False))
    return 0


if __name__ == "__main__":
    sys.exit(main())
