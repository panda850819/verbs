#!/usr/bin/env python3
"""drive-pulse — the autonomous loop's self vital-signs read (PRO-44 / read-side).

The loop verifies each unit of work green but has no read of its own health: Goal A's
success signal (auto-merge count, agreement streak, zero fake-green) lives only as prose
in goals/pandastack-universal-harness.md and nothing computes it over a window. This
renders a windowed, no-threshold, dated vital-signs report from drive-log.jsonl:

  HEADLINES  — host-verified PASS, advance proposals, gate hits, kill-switch suppressed
               ticks, executor errors — each with delta vs the prior equal-length window.
  NO DATA    — signals not instrumented yet (fake-green needs verify_ran; streak needs
               auto-merge ticks). Rendered, never silently dropped, so the instrumentation
               deficit is visible every day instead of hidden.
  VITAL SIGNS— top gated ids, top stuck-PASS ids.
  FOLLOWUPS  — wraps drive-log-distill (the constraint-proposer); pulse is the reader.

Read-only, judgment-free, never mutates — so the autonomous daemon can consume its own
pulse with zero human-in-loop ceremony.

  drive-pulse <drive-log.jsonl> [--now YYYY-MM-DD] [--days 7] [--json]
"""
import argparse
import datetime
import json
import os
import re
import subprocess
import sys
from collections import Counter

HERE = os.path.dirname(os.path.abspath(__file__))
DISTILL = os.path.join(HERE, "drive-log-distill")


def parse_date(ts):
    return datetime.date.fromisoformat(str(ts)[:10])


def window_stats(rows):
    pass_count, gate_count = Counter(), Counter()
    passes = advances = suppressed = errors = 0
    for r in rows:
        if r.get("suppressed"):
            suppressed += 1
            continue
        for e in r.get("executed", []):
            if e.get("verdict") == "PASS":
                passes += 1
                pass_count[e["id"]] += 1
            if e.get("advance"):
                advances += 1
        for gid in r.get("gate_ids", []):
            gate_count[gid] += 1
        if r.get("error"):
            errors += 1
    return {"ticks": len(rows), "passes": passes, "advances": advances,
            "gates": sum(gate_count.values()), "suppressed": suppressed, "errors": errors,
            "top_gated": gate_count.most_common(3), "top_stuck_pass": pass_count.most_common(3)}


def executed_rows(rows):
    for r in rows:
        for e in r.get("executed", []):
            yield e


def fake_green_rows(rows):
    """The goal's fake-green counter-example: a PASS that proposed a verify-required
    advance/merge with no host-verify run. Healthy count is 0. Now computable because
    LG records verify_ran/verify_required per item (F-K/F-L)."""
    return [e for e in executed_rows(rows)
            if e.get("verdict") == "PASS" and (e.get("advance") or e.get("merged"))
            and e.get("verify_required") and not e.get("verify_ran")]


def merge_events(rows):
    """Auto-merge events in chronological (append) order."""
    return [e for e in executed_rows(rows) if e.get("merged")]


def reverts_on_branch(repo, branch):
    """Shas a human reverted on `branch` — git revert writes 'This reverts commit <sha>'.
    None = can't tell (no repo / git error), so the streak notes the revert-check was skipped.
    A rollback that rewrites history (reset / branch -f / rebase) leaves no revert message;
    that disconfirm is caught separately by rolled_back_shas (reachability)."""
    if not repo:
        return None
    cp = subprocess.run(["git", "-C", os.path.expanduser(repo), "log", branch, "--format=%b"],
                        capture_output=True, text=True)
    if cp.returncode != 0:
        return None
    return set(re.findall(r"[Tt]his reverts commit ([0-9a-f]{7,40})", cp.stdout))


def rolled_back_shas(repo, branch, shas):
    """Auto-merged shas no longer reachable from the branch HEAD — silently rolled back via
    reset / `git branch -f` / rebase, which a 'This reverts commit' grep cannot see. A real
    disconfirm: a merge that earned a streak point is no longer in integration. None if no
    repo (check skipped). This is what stops a phantom 20/20 after a history-rewrite rollback."""
    if not repo:
        return None
    rolled = set()
    for sha in shas:
        if not sha:
            continue
        cp = subprocess.run(["git", "-C", os.path.expanduser(repo), "merge-base",
                             "--is-ancestor", sha, branch], capture_output=True, text=True)
        if cp.returncode == 1:        # 0 = still an ancestor; 1 = gone (rolled back); other = unknown → skip
            rolled.add(sha)
    return rolled


def trust_streak(events, reverted):
    """Consecutive auto-merges with no human-revert; the first disconfirm resets to 0
    (goal: 'agreement streak 連 20 筆無 revert；首次 disconfirm 歸零'). reverted=None means
    no revert evidence was checked, so this counts raw consecutive merges."""
    streak = 0
    for e in events:
        sha = e.get("merged_sha")
        if reverted and sha and any(sha.startswith(rv) or rv.startswith(sha) for rv in reverted):
            streak = 0
        else:
            streak += 1
    return streak


def goal_signals(cur_rows, all_rows, repo):
    """Goal A's success signal, computed (no longer NO DATA): zero fake-green over the
    window, and the trust streak (trailing clean auto-merges) across all history."""
    fg = fake_green_rows(cur_rows)
    evs = merge_events(all_rows)
    integ = evs[-1]["merged"] if evs else "psdrive/integration"
    reverted = reverts_on_branch(repo, integ)                                  # None if no repo / git error
    rolled = rolled_back_shas(repo, integ, [e.get("merged_sha") for e in evs])  # None if no repo
    checked = reverted is not None or rolled is not None
    # a streak point is disconfirmed by EITHER an explicit revert OR a silent rollback
    disconfirmed = ((reverted or set()) | (rolled or set())) if checked else None
    return {
        "fake_green": len(fg),
        "fake_green_ids": [e.get("id") for e in fg],
        "merges_total": len(evs),
        "trust_streak": trust_streak(evs, disconfirmed),
        "streak_target": 20,
        "revert_checked": checked,
        "reverts_seen": (len(reverted) if reverted is not None else None),
        "rolled_back": (len(rolled) if rolled is not None else None),
    }


def main(argv):
    ap = argparse.ArgumentParser(prog="drive-pulse")
    ap.add_argument("log")
    ap.add_argument("--now", help="window anchor date YYYY-MM-DD (default today)")
    ap.add_argument("--days", type=int, default=7)
    ap.add_argument("--repo", help="repo whose integration branch to check for human-reverts (trust streak)")
    ap.add_argument("--json", action="store_true")
    a = ap.parse_args(argv)

    now = datetime.date.fromisoformat(a.now) if a.now else datetime.date.today()
    cur_start = now - datetime.timedelta(days=a.days)
    prev_start = now - datetime.timedelta(days=2 * a.days)
    rows = [json.loads(l) for l in open(a.log, encoding="utf-8") if l.strip()]
    cur = [r for r in rows if cur_start <= parse_date(r["ts"]) < now]
    prev = [r for r in rows if prev_start <= parse_date(r["ts"]) < cur_start]
    cs, ps = window_stats(cur), window_stats(prev)
    signals = goal_signals(cur, rows, a.repo)

    followups = ""
    try:
        fp = subprocess.run([sys.executable, DISTILL, a.log], capture_output=True, text=True, timeout=60)
        followups = fp.stdout.strip()
    except Exception as e:  # distill is a convenience wrap; never let it break the pulse
        followups = f"(drive-log-distill unavailable: {e})"

    if a.json:
        print(json.dumps({"now": now.isoformat(), "days": a.days, "current": cs, "prior": ps,
                          "goal_signals": signals, "followups": followups}, ensure_ascii=False))
        return 0

    def sign(n):
        return f"+{n}" if n > 0 else str(n)

    print(f"=== drive-pulse · {now.isoformat()} · rolling {a.days}d ===\n")
    print("HEADLINES (Δ vs prior window):")
    for k, label in [("passes", "host-verified PASS"), ("advances", "advance proposals"),
                     ("gates", "gate hits"), ("suppressed", "kill-switch suppressed ticks"),
                     ("errors", "executor errors")]:
        print(f"  {label:32} {cs[k]:>4}  ({sign(cs[k] - ps[k])})")
    fg = signals["fake_green"]
    fg_line = "0 ✓" if fg == 0 else f"{fg} ✗  {signals['fake_green_ids']}"
    if signals["revert_checked"]:
        streak_line = (f"{signals['trust_streak']}/{signals['streak_target']}"
                       f"  ({signals['merges_total']} merges, {signals['reverts_seen']} reverts, "
                       f"{signals['rolled_back']} rolled-back)")
    else:
        streak_line = (f"{signals['trust_streak']}/{signals['streak_target']} raw"
                       f"  ({signals['merges_total']} merges; revert-check skipped — pass --repo)")
    print("\nGOAL SIGNAL (Goal A success criteria):")
    print(f"  fake-green (window)  {fg_line}")
    print(f"  trust streak         {streak_line}")
    print("\nVITAL SIGNS:")
    print("  top gated:      " + (", ".join(f"{i}×{c}" for i, c in cs["top_gated"]) or "—"))
    print("  top stuck-PASS: " + (", ".join(f"{i}×{c}" for i, c in cs["top_stuck_pass"]) or "—"))
    print("\nFOLLOWUPS (from drive-log-distill):")
    print("  " + (followups.replace("\n", "\n  ") if followups else "—"))
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
