#!/usr/bin/env python3
"""pandastack-linear-reduce — reduce Linear issues to "what's most urgent today".

The scheduler's pure decision core: given a set of issues (from a fixture now, or
the live Linear API in --source linear later), apply the eligibility predicate
and stable sort from plugins/pandastack/docs/linear-contract.md, and split them
into dispatchable / gated / blocked. The LLM never picks — this is deterministic.

Contract: plugins/pandastack/docs/linear-contract.md (lifecycle-map, needs-human,
acceptance-format, active-terminal-states).

Usage:
  pandastack-linear-reduce --source fixture --file issues.json [--json]
  pandastack-linear-reduce --source linear  --project <id>     [--json]   # T03

Issue shape (fixture / normalized from Linear):
  {"identifier":"MUR-1","title":"...","state":"Building","priority":2,
   "labels":["..."],"blocked_by":["MUR-3"],"created_at":"2026-06-10T00:00:00Z"}
Linear priority: 0=None 1=Urgent 2=High 3=Medium 4=Low.
"""
import argparse
import json
import sys

TERMINAL_STATES = {"Done", "Canceled", "Cancelled"}
TERMINAL_TYPES = {"completed", "canceled", "cancelled"}
GATE_STATE = "Needs Decision"
GATE_LABEL = "needs-human"
# active = anything not terminal (symphony model); the gate is applied on top.
# No active-state allowlist: live Linear teams use custom state names, so we
# classify by terminality + gate, not by a fixed name set.


def is_terminal(issue):
    # accept a normalized issue dict (live Linear carries state_type) or a bare
    # state string (fixtures, back-compat).
    if isinstance(issue, dict):
        return (issue.get("state") in TERMINAL_STATES
                or issue.get("state_type") in TERMINAL_TYPES)
    return issue in TERMINAL_STATES


def is_gated(issue):
    return issue.get("state") == GATE_STATE or GATE_LABEL in issue.get("labels", [])


def prio_rank(p):
    # Linear: 1=Urgent..4=Low are real; 0=None sorts LAST (symphony "null last").
    return p if isinstance(p, int) and 1 <= p <= 4 else 99


def reduce_issues(issues):
    by_id = {i.get("identifier"): i for i in issues}

    def blocker_open(issue):
        for bid in issue.get("blocked_by", []) or []:
            blk = by_id.get(bid)
            # blocker not in the set → assume resolved/terminal (non-blocking);
            # present and non-terminal → still blocking.
            if blk is not None and not is_terminal(blk):
                return True
        return False

    dispatchable, gated, blocked = [], [], []
    for i in issues:
        if is_terminal(i):
            continue                      # terminal: skipped entirely
        if is_gated(i):
            gated.append(i)               # hard gate: surface, never dispatch
        elif blocker_open(i):
            blocked.append(i)             # waiting on a non-terminal blocker
        else:
            dispatchable.append(i)

    dispatchable.sort(key=lambda i: (prio_rank(i.get("priority", 0)),
                                     i.get("created_at", "")))
    return {"dispatchable": dispatchable, "gated": gated, "blocked": blocked}


def load_fixture(path):
    with open(path, encoding="utf-8") as f:
        data = json.load(f)
    return data["issues"] if isinstance(data, dict) and "issues" in data else data


def load_linear(project_id=None):
    import os
    import re
    import urllib.request
    key = os.environ.get("LINEAR_API_KEY")
    if not key:
        sys.exit("error: LINEAR_API_KEY not set (source ~/.config/pandastack/secrets.env)")

    def post(query, variables=None):
        body = {"query": query}
        if variables is not None:
            body["variables"] = variables
        req = urllib.request.Request(
            "https://api.linear.app/graphql",
            data=json.dumps(body).encode("utf-8"),
            headers={"Authorization": key, "Content-Type": "application/json"})
        try:
            with urllib.request.urlopen(req, timeout=30) as r:
                payload = json.loads(r.read().decode("utf-8"))
        except Exception as e:
            sys.exit(f"Linear API request failed: {e}")
        if "errors" in payload:
            sys.exit("Linear API error: " + json.dumps(payload["errors"], ensure_ascii=False))
        return payload["data"]

    # project_id is a self-provided Linear UUID; validate its shape so it can never
    # rewrite a query, then pass it as a GraphQL variable (not interpolated).
    if project_id and not re.fullmatch(r'[0-9a-fA-F-]{8,}', project_id):
        sys.exit(f"error: invalid Linear project id {project_id!r}")

    # guard: resolve the project id before filtering on it. A typo'd / deleted id
    # would otherwise pass through and return an empty set that reads as "nothing
    # urgent today" — a silent mis-config in an unattended loop. Fail loud instead.
    if project_id and not post('query($pid:String!){project(id:$pid){id}}',
                               {"pid": project_id}).get("project"):
        sys.exit(f"error: Linear project {project_id} not found")

    # pull non-terminal issues; blocked_by derived from inverse "blocks" relations.
    flt = '{state: {type: {nin: ["completed","canceled"]}}}'
    variables = None
    qhead = "query"
    if project_id:
        flt = '{and: [%s, {project: {id: {eq: $pid}}}]}' % flt
        variables = {"pid": project_id}
        qhead = "query($pid:ID!)"
    query = (qhead + '{ issues(first: 100, filter: %s) { nodes { '
             'identifier title priority createdAt '
             'state { name type } '
             'project { name } '
             'labels { nodes { name } } '
             'inverseRelations { nodes { type issue { identifier } } } '
             '} } }') % flt
    out = []
    for n in post(query, variables)["issues"]["nodes"]:
        blocked_by = [rel["issue"]["identifier"]
                      for rel in n.get("inverseRelations", {}).get("nodes", [])
                      if rel.get("type") == "blocks" and rel.get("issue")]
        out.append({
            "identifier": n["identifier"],
            "project": (n.get("project") or {}).get("name"),
            "title": n.get("title", ""),
            "priority": n.get("priority", 0),
            "state": n["state"]["name"],
            "state_type": n["state"]["type"],
            "labels": [l["name"] for l in n.get("labels", {}).get("nodes", [])],
            "blocked_by": blocked_by,
            "created_at": n.get("createdAt", ""),
        })
    return out


def main():
    ap = argparse.ArgumentParser(prog="pandastack-linear-reduce")
    ap.add_argument("--source", choices=["fixture", "linear"], required=True)
    ap.add_argument("--file", help="fixture JSON path (--source fixture)")
    ap.add_argument("--project", help="Linear project id (--source linear)")
    ap.add_argument("--json", action="store_true")
    args = ap.parse_args()

    if args.source == "fixture":
        if not args.file:
            ap.error("--source fixture requires --file")
        issues = load_fixture(args.file)
    else:
        issues = load_linear(args.project)

    result = reduce_issues(issues)
    if args.json:
        print(json.dumps(result, ensure_ascii=False, indent=2))
    else:
        def line(i):
            return f"  {i.get('identifier',''):<8} p{i.get('priority',0)} {i.get('state',''):<14} {i.get('title','')}"
        print("DISPATCHABLE (most urgent first):")
        for i in result["dispatchable"]:
            print(line(i))
        print("GATED (needs human, not dispatched):")
        for i in result["gated"]:
            print(line(i))
        print("BLOCKED (waiting on a blocker):")
        for i in result["blocked"]:
            print(line(i))
    return 0


if __name__ == "__main__":
    sys.exit(main())
