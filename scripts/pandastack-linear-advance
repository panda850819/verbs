#!/usr/bin/env python3
"""pandastack-linear-advance — the ONE human-invoked Linear write in the scheduler loop.

Move a Linear issue to a named workflow state and record a matching
pandastack-state phase_enter event. You pick the target; adjacency is not enforced
(this is a human-invoked move). The Hermes cron NEVER calls this; Panda runs it by
hand after doing (or okaying) the work. A GATED issue (Needs Decision state or
needs-human label) is refused unless --force, because that is a human decision.

Reads LINEAR_API_KEY from env or ~/.config/pandastack/secrets.env. Same API path
as pandastack-linear-reduce (no MCP).

  pandastack-linear-advance --issue PRO-9 --to "In Progress"
  pandastack-linear-advance --issue PRO-9 --to "In Progress" --dry-run
"""
import argparse, json, os, re, subprocess, sys, urllib.request, pathlib

PHASE = {"Backlog": "DEFINE", "Todo": "PLAN", "Planning": "PLAN",
         "In Progress": "BUILD", "Building": "BUILD", "Verifying": "VERIFY",
         "In Review": "REVIEW", "Done": "SHIP", "Needs Decision": "GATE",
         "Canceled": "killed", "Duplicate": "killed"}


def load_key():
    k = os.environ.get("LINEAR_API_KEY")
    if k:
        return k
    env = pathlib.Path.home() / ".config/pandastack/secrets.env"
    if env.exists():
        for line in env.read_text().splitlines():
            m = re.match(r'\s*LINEAR_API_KEY\s*=\s*(.+)\s*$', line)
            if m:
                return m.group(1).strip().strip('"').strip("'")
    sys.exit("error: LINEAR_API_KEY not set (env or ~/.config/pandastack/secrets.env)")


def post(key, q, v=None):
    body = {"query": q}
    if v is not None:
        body["variables"] = v
    req = urllib.request.Request(
        "https://api.linear.app/graphql",
        data=json.dumps(body).encode("utf-8"),
        headers={"Authorization": key, "Content-Type": "application/json"})
    try:
        with urllib.request.urlopen(req, timeout=30) as r:
            p = json.loads(r.read().decode("utf-8"))
    except Exception as e:
        sys.exit(f"Linear API request failed: {e}")
    if "errors" in p:
        sys.exit("Linear API error: " + json.dumps(p["errors"], ensure_ascii=False))
    return p["data"]


def main():
    ap = argparse.ArgumentParser(prog="pandastack-linear-advance")
    ap.add_argument("--issue", required=True, help="issue identifier, e.g. PRO-9")
    ap.add_argument("--to", required=True, help="target workflow state name, e.g. 'In Progress'")
    ap.add_argument("--slug", default="murmur", help="pandastack-state project slug")
    ap.add_argument("--dry-run", action="store_true", help="print the planned change, write nothing")
    ap.add_argument("--force", action="store_true", help="override the needs-human / Needs Decision gate")
    a = ap.parse_args()

    m = re.match(r'^([A-Za-z]+)-(\d+)$', a.issue.strip())
    if not m:
        sys.exit(f"error: bad issue identifier {a.issue!r} (expected like PRO-9)")
    team_key, num = m.group(1).upper(), int(m.group(2))
    key = load_key()

    d = post(key,
             'query($k:String!,$n:Float!){issues(filter:{team:{key:{eq:$k}},number:{eq:$n}})'
             '{nodes{id identifier title state{name} team{id} labels{nodes{name}}}}}',
             {"k": team_key, "n": num})
    nodes = d["issues"]["nodes"]
    if not nodes:
        sys.exit(f"error: issue {a.issue} not found")
    iss = nodes[0]
    cur = iss["state"]["name"]
    labels = [l["name"] for l in iss["labels"]["nodes"]]

    # gate guard: a gated issue is a human decision; never advance it silently.
    if (cur == "Needs Decision" or "needs-human" in labels) and not a.force:
        sys.exit(f"refused: {a.issue} is GATED (state={cur}, labels={labels}). "
                 f"It is a human decision — make the call, then re-run with --force.")

    ts = post(key, 'query($t:String!){team(id:$t){states{nodes{id name}}}}', {"t": iss["team"]["id"]})
    by_name = {s["name"].lower(): s for s in ts["team"]["states"]["nodes"]}
    tgt = by_name.get(a.to.strip().lower())
    if not tgt:
        have = [s["name"] for s in ts["team"]["states"]["nodes"]]
        sys.exit(f"error: target state {a.to!r} not in team. Have: {have}")
    phase = PHASE.get(tgt["name"])
    if phase is None:   # never invent a phase: a silent default corrupts the state log
        sys.exit(f"error: no phase mapping for state {tgt['name']!r}. "
                 f"Add it to PHASE or pick a mapped state: {sorted(PHASE)}")

    print(f"{a.issue}: {cur} -> {tgt['name']}  (phase {phase})")
    if a.dry_run:
        print("DRY RUN: would issueUpdate + pandastack-state append phase_enter. No write.")
        return

    res = post(key, 'mutation($id:String!,$s:String!){issueUpdate(id:$id,input:{stateId:$s}){success}}',
               {"id": iss["id"], "s": tgt["id"]})
    if not res.get("issueUpdate", {}).get("success"):   # 200 + success=false (perm/validation) ≠ done
        sys.exit(f"error: Linear issueUpdate returned success=false for {a.issue} (no state change)")
    print("  Linear: state updated")

    here = pathlib.Path(__file__).resolve().parent
    try:
        subprocess.run([sys.executable, str(here / "pandastack-state"), "append",
                        "--slug", a.slug, "--item", a.issue, "--event", "phase_enter",
                        "--phase", phase, "--skill", "scheduler-advance",
                        "--runtime", "claude-code", "--ref", iss["identifier"]], check=True)
        print("  pandastack-state: phase_enter appended")
    except Exception as e:
        # Linear already advanced; a missing phase_enter diverges the audit log from
        # Linear. Surface the partial write loudly (non-zero) with the recovery cmd.
        sys.exit(f"error: Linear advanced to {tgt['name']} but pandastack-state append FAILED ({e}).\n"
                 f"  re-append: pandastack-state append --slug {a.slug} --item {a.issue} "
                 f"--event phase_enter --phase {phase} --skill scheduler-advance --runtime claude-code")


if __name__ == "__main__":
    main()
