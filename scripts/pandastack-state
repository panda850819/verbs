#!/usr/bin/env python3
"""pandastack-state — append-only lifecycle state store for loop-in-agent.

One event log per project: ~/.pandastack/projects/<slug>/state.jsonl
Skills append phase-boundary + terminal events; schedulers reduce to the active
state per work-item and decide the next step against DISPATCH.md.

Design contract (grilled 2026-06-13):
  - event-sourced, append-only: multi-runtime (Claude/Codex/Hermes) writers never
    race on a shared file; active state is COMPUTED, never overwritten.
  - timestamps + run_id are produced HERE, not by the model — the model decides
    WHAT happened, the program records WHEN (resume breaks if the model invents ts).

Schema + full reference: docs/state-schema.md

Usage:
  pandastack-state append --slug <repo> --item <name> --event phase_enter \\
      --phase BUILD --skill sprint --runtime claude-code [--ref PATH] [--note TXT]
  pandastack-state reduce --slug <repo> [--item <name>] [--json]
  pandastack-state next   --slug <repo>            # active items needing a step
  pandastack-state path   --slug <repo>
"""
import argparse
import json
import os
import sys
import uuid
from datetime import datetime, timezone

PHASES = ["DEFINE", "PLAN", "GATE", "BUILD", "VERIFY", "REVIEW", "SHIP"]
EVENTS = ["phase_enter", "paused", "resumed", "shipped", "failed", "aborted", "delegated"]
TERMINAL = {"shipped", "failed", "aborted"}
RUNTIMES = ["claude-code", "codex", "hermes", "other"]

# status implied by the LAST event for an item (reducer output)
STATUS_BY_EVENT = {
    "phase_enter": "in_progress",
    "resumed": "in_progress",
    "delegated": "in_progress",
    "paused": "paused",
    "shipped": "shipped",
    "failed": "failed",
    "aborted": "aborted",
}


def store_dir(slug):
    root = os.environ.get("PANDASTACK_STATE_HOME", os.path.expanduser("~/.pandastack"))
    return os.path.join(root, "projects", slug)


def store_path(slug):
    return os.path.join(store_dir(slug), "state.jsonl")


def cmd_path(args):
    print(store_path(args.slug))
    return 0


def cmd_append(args):
    if args.event not in EVENTS:
        sys.exit(f"error: --event must be one of {EVENTS}")
    if args.event == "phase_enter" and args.phase not in PHASES:
        sys.exit(f"error: phase_enter requires --phase in {PHASES}")
    if args.phase and args.phase not in PHASES:
        sys.exit(f"error: --phase must be one of {PHASES}")
    if args.runtime not in RUNTIMES:
        sys.exit(f"error: --runtime must be one of {RUNTIMES}")

    event = {
        "ts": datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"),
        "run_id": args.run_id or uuid.uuid4().hex[:12],
        "skill": args.skill,
        "runtime": args.runtime,
        "item": args.item,
        "event": args.event,
        "phase": args.phase or None,
        "ref": args.ref or None,
        "note": args.note or None,
    }
    d = store_dir(args.slug)
    os.makedirs(d, exist_ok=True)
    # one atomic line append; multiple writers are safe (O_APPEND on POSIX)
    line = json.dumps(event, ensure_ascii=False)
    with open(store_path(args.slug), "a", encoding="utf-8") as f:
        f.write(line + "\n")
    print(line)
    return 0


def read_events(slug):
    p = store_path(slug)
    if not os.path.exists(p):
        return []
    events = []
    with open(p, encoding="utf-8") as f:
        for ln, raw in enumerate(f, 1):
            raw = raw.strip()
            if not raw:
                continue
            try:
                events.append(json.loads(raw))
            except json.JSONDecodeError:
                sys.stderr.write(f"warn: corrupt line {ln} in {p}, skipped\n")
    return events


def reduce_state(slug):
    """Fold the event log into one active state per item (last event wins)."""
    by_item = {}
    for e in read_events(slug):
        item = e.get("item")
        if not item:
            continue
        cur = by_item.setdefault(item, {"item": item, "phase": None, "status": None,
                                        "runtime": None, "ref": None, "last_ts": None,
                                        "events": 0})
        cur["events"] += 1
        cur["last_ts"] = e.get("ts")
        cur["runtime"] = e.get("runtime")
        ev = e.get("event")
        cur["status"] = STATUS_BY_EVENT.get(ev, cur["status"])
        # phase tracks the last phase we entered; terminal/paused keep it
        if e.get("phase"):
            cur["phase"] = e["phase"]
        if e.get("ref"):
            cur["ref"] = e["ref"]
        cur["owner"] = "codex" if ev == "delegated" else cur.get("owner")
    return by_item


def cmd_reduce(args):
    state = reduce_state(args.slug)
    if args.item:
        state = {k: v for k, v in state.items() if k == args.item}
    if args.json:
        print(json.dumps(list(state.values()), ensure_ascii=False, indent=2))
    else:
        if not state:
            print("(no state)")
        for v in state.values():
            print(f"{v['item']:<24} {str(v['phase'] or '-'):<8} {v['status']:<12} "
                  f"{v['runtime'] or '-':<12} {v['last_ts'] or ''}")
    return 0


def cmd_next(args):
    """Active items (not terminal) — what a scheduler would consider stepping."""
    state = reduce_state(args.slug)
    active = [v for v in state.values() if v["status"] not in TERMINAL]
    if args.json:
        print(json.dumps(active, ensure_ascii=False, indent=2))
        return 0
    if not active:
        print("(nothing active)")
    for v in active:
        nxt = NEXT_PHASE.get(v["phase"], "?")
        print(f"{v['item']:<24} at {str(v['phase'] or '-'):<8} ({v['status']}) "
              f"-> next phase: {nxt}")
    return 0


# advisory only — the scheduler maps phase -> skill via DISPATCH.md, not here
NEXT_PHASE = {
    "DEFINE": "PLAN", "PLAN": "GATE", "GATE": "BUILD", "BUILD": "VERIFY",
    "VERIFY": "REVIEW", "REVIEW": "SHIP", "SHIP": "(done)",
}


def main():
    ap = argparse.ArgumentParser(prog="pandastack-state", description=__doc__,
                                 formatter_class=argparse.RawDescriptionHelpFormatter)
    sub = ap.add_subparsers(dest="cmd", required=True)

    a = sub.add_parser("append", help="append one event")
    a.add_argument("--slug", required=True)
    a.add_argument("--item", required=True)
    a.add_argument("--event", required=True)
    a.add_argument("--phase")
    a.add_argument("--skill", required=True)
    a.add_argument("--runtime", default="claude-code")
    a.add_argument("--ref")
    a.add_argument("--note")
    a.add_argument("--run-id", dest="run_id")
    a.set_defaults(func=cmd_append)

    r = sub.add_parser("reduce", help="show active state per item")
    r.add_argument("--slug", required=True)
    r.add_argument("--item")
    r.add_argument("--json", action="store_true")
    r.set_defaults(func=cmd_reduce)

    n = sub.add_parser("next", help="list active items + advisory next phase")
    n.add_argument("--slug", required=True)
    n.add_argument("--json", action="store_true")
    n.set_defaults(func=cmd_next)

    p = sub.add_parser("path", help="print the state.jsonl path")
    p.add_argument("--slug", required=True)
    p.set_defaults(func=cmd_path)

    args = ap.parse_args()
    return args.func(args)


if __name__ == "__main__":
    sys.exit(main())
