#!/usr/bin/env python3
"""Compatibility shim for the retired pandastack CLI path."""
import os
import sys
from pathlib import Path


target = Path(__file__).resolve().with_name("verbs")
print(
    "DEPRECATED: scripts/pandastack moved to scripts/verbs.",
    file=sys.stderr,
)
for legacy, current in (
    ("PANDA_VERBS_REPO_ROOT", "VERBS_REPO_ROOT"),
    ("PANDA_VERBS_MANIFEST", "VERBS_MANIFEST"),
    ("PANDASTACK_REPO_ROOT", "VERBS_REPO_ROOT"),
    ("PANDASTACK_MANIFEST", "VERBS_MANIFEST"),
):
    if current not in os.environ and legacy in os.environ:
        os.environ[current] = os.environ[legacy]

try:
    os.execv(str(target), [str(target), *sys.argv[1:]])
except OSError as exc:
    print(f"ERROR: cannot execute {target}: {exc}", file=sys.stderr)
    raise SystemExit(1)
