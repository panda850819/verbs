#!/usr/bin/env python3
"""pandastack CLI — doctor and init front-door. Python stdlib only."""
import argparse
import datetime
import json
import os
import shutil
import sys
from pathlib import Path

REPO_ROOT = Path(__file__).resolve().parent.parent
_DEFAULT_MANIFEST = REPO_ROOT / "plugins/pandastack/manifest.toml"
MANIFEST_PATH = Path(os.environ.get("PANDASTACK_MANIFEST", str(_DEFAULT_MANIFEST)))
DISPATCH_PATH = REPO_ROOT / "plugins/pandastack/DISPATCH.md"
SKILLS_DIR = REPO_ROOT / "plugins/pandastack/skills"
AGENT_WORKER_PATH = REPO_ROOT / "scripts/agent-worker"

# Schema version for capabilities.json / runtimes.json. Mirrored in pandastack.toml
# ([capabilities] schema_version) and the test suites; bump all sites together.
SCHEMA_VERSION = 1

_DETECT_CMDS = [
    "claude", "codex", "git", "python3", "bash",
    "agent-browser", "curl", "jq", "pdctx", "hermes", "launchctl",
]


# ---------------------------------------------------------------------------
# Minimal TOML parser (handles manifest.toml structure; no external deps)
# ---------------------------------------------------------------------------

def _parse_toml_minimal(text):
    """Parse a subset of TOML sufficient for manifest.toml.

    Handles: [section], [section.key], key = "string", key = ["list"], bool,
    int, and a trailing inline comment (# ...) after a scalar value.
    Limitation: no multi-line values, no inline tables, no dotted keys, and
    commas inside quoted list items are not respected.
    """
    result = {}
    current = result

    for raw_line in text.splitlines():
        line = raw_line.strip()
        if not line or line.startswith("#"):
            continue

        if line.startswith("[") and line.endswith("]"):
            inner = line[1:-1]
            parts = inner.split(".")
            node = result
            for part in parts:
                node = node.setdefault(part, {})
            current = node
            continue

        if "=" in line:
            key, _, val = line.partition("=")
            key = key.strip()
            val = val.strip()
            if val.startswith('"'):
                # Quoted string: value ends at the closing quote; ignore any
                # trailing inline comment.
                end = val.find('"', 1)
                current[key] = val[1:end] if end != -1 else val[1:]
            elif val.startswith("["):
                # Single-line list: value ends at the closing bracket.
                end = val.find("]")
                inner = val[1:end] if end != -1 else val[1:]
                items = [
                    v.strip().strip('"')
                    for v in inner.split(",")
                    if v.strip().strip('"')
                ]
                current[key] = items
            else:
                # Bareword / int / bool: strip any trailing inline comment.
                val = val.split("#", 1)[0].strip()
                if val in ("true", "false"):
                    current[key] = val == "true"
                else:
                    try:
                        current[key] = int(val)
                    except ValueError:
                        current[key] = val

    return result


def load_manifest():
    """Return (ok, error_message, data)."""
    if not MANIFEST_PATH.exists():
        return False, f"manifest.toml not found at {MANIFEST_PATH}", {}
    try:
        text = MANIFEST_PATH.read_text()
    except OSError as exc:
        return False, f"Cannot read manifest.toml: {exc}", {}
    try:
        try:
            import tomllib  # Python 3.11+
            data = tomllib.loads(text)
        except ImportError:
            data = _parse_toml_minimal(text)
    except Exception as exc:
        return False, f"Failed to parse manifest.toml: {exc}", {}
    return True, None, data


# ---------------------------------------------------------------------------
# Substrate checks
# ---------------------------------------------------------------------------

def check_substrate():
    """Return list of substrate check dicts. Uses HOME env var."""
    home = Path.home()
    agents_md = home / ".agents" / "AGENTS.md"

    def _check(name, path, ok, fix=None):
        return {"name": name, "ok": ok, "path": str(path),
                "message": "present" if ok else "missing", "fix": fix}

    return [
        _check(
            "substrate.agents_md", agents_md, agents_md.exists(),
            fix=(f"mkdir -p {home}/.agents && "
                 f"# create {home}/.agents/AGENTS.md (see README § Substrate)")
            if not agents_md.exists() else None,
        ),
        _check("substrate.manifest", MANIFEST_PATH, MANIFEST_PATH.exists()),
        _check("substrate.dispatch", DISPATCH_PATH, DISPATCH_PATH.exists()),
        _check("substrate.skills_dir", SKILLS_DIR, SKILLS_DIR.is_dir()),
    ]


def check_manifest_skills(manifest_data):
    """Return manifest check dict with skill counts and drift info."""
    skill_section = manifest_data.get("skill", {})

    core = [k for k, v in skill_section.items()
            if isinstance(v, dict) and v.get("tier") == "core"]
    ext = [k for k, v in skill_section.items()
           if isinstance(v, dict) and v.get("tier") == "ext"]

    disk_skills = set()
    if SKILLS_DIR.is_dir():
        for entry in SKILLS_DIR.iterdir():
            if entry.is_dir() and entry.name != ".archive":
                disk_skills.add(entry.name)

    manifest_skills = set(skill_section.keys())
    missing_on_disk = sorted(manifest_skills - disk_skills)
    missing_in_manifest = sorted(disk_skills - manifest_skills)

    return {
        "ok": not missing_on_disk and not missing_in_manifest,
        "skill_counts": {
            "total": len(skill_section),
            "core": len(core),
            "ext": len(ext),
        },
        "drift": {
            "missing_on_disk": missing_on_disk,
            "missing_in_manifest": missing_in_manifest,
        },
    }


# ---------------------------------------------------------------------------
# Runtime detection
# ---------------------------------------------------------------------------

def detect_runtimes():
    """Return {cmd: bool} for each tracked command."""
    return {cmd: shutil.which(cmd) is not None for cmd in _DETECT_CMDS}


def _worker_status(agent_worker_present, codex_ready):
    """Derive worker role status from agent-worker + codex backend presence."""
    if agent_worker_present and codex_ready:
        return "ready"
    return "degraded" if agent_worker_present else "missing"


def derive_roles(runtimes):
    """Return roles dict with host/worker/operator sub-dicts."""
    agent_worker_present = AGENT_WORKER_PATH.exists()
    codex_ready = runtimes.get("codex", False)
    pdctx_ready = runtimes.get("pdctx", False)

    host = {
        "claude": {
            "ready": runtimes.get("claude", False),
            "install_hint": (
                f"/plugin marketplace add {REPO_ROOT}\n"
                "/plugin install pandastack@pandastack\n"
                "/reload-plugins"
            ) if not runtimes.get("claude") else None,
        },
        "codex": {
            "ready": codex_ready,
            "install_hint": (
                f"mkdir -p $HOME/.codex/skills\n"
                f"ln -sfn {REPO_ROOT}/plugins/pandastack/skills"
                " $HOME/.codex/skills/pandastack"
            ) if not codex_ready else None,
        },
        "hermes": {
            "ready": pdctx_ready,
            "status": "supported-as-scheduler" if pdctx_ready else "degraded",
            "note": (
                "pdctx present — Hermes supported as scheduler/operator"
                if pdctx_ready
                else "pdctx missing — Hermes support degraded (see docs/HERMES.md)"
            ),
        },
    }

    worker_warnings = []
    if not codex_ready:
        worker_warnings.append(
            "codex not found — production backend unavailable; "
            "test backend works for offline checks"
        )
    if not agent_worker_present:
        worker_warnings.append(
            f"scripts/agent-worker not found at {AGENT_WORKER_PATH}"
        )

    worker_status = _worker_status(agent_worker_present, codex_ready)

    worker = {
        "agent_worker_present": agent_worker_present,
        "codex_backend_ready": codex_ready,
        "test_backend_ready": True,
        "status": worker_status,
        "warnings": worker_warnings,
    }

    operator_launchd = runtimes.get("launchctl", False) and sys.platform == "darwin"
    operator = {
        "shell_manual": True,
        "launchd": operator_launchd,
        "hermes_cron": pdctx_ready,
        "status": "scheduled" if (operator_launchd or pdctx_ready) else "shell-only",
    }

    return {"host": host, "worker": worker, "operator": operator}


# ---------------------------------------------------------------------------
# Capability-map helpers
# ---------------------------------------------------------------------------

def _get_now():
    """Return ISO UTC timestamp. Respects PANDASTACK_NOW for deterministic tests."""
    ts = os.environ.get("PANDASTACK_NOW")
    if ts:
        return ts
    return datetime.datetime.now(datetime.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")


def _safe_write_json(path, data):
    """Write JSON to path, refusing to follow a pre-existing symlink.

    Guards against a symlink-attack where another process pre-creates the
    target as a symlink so a privileged write lands on an arbitrary file.
    """
    path.parent.mkdir(parents=True, exist_ok=True)
    if path.is_symlink():
        raise OSError(f"refusing to write through symlink: {path}")
    fd = os.open(
        str(path),
        os.O_WRONLY | os.O_CREAT | os.O_TRUNC | os.O_NOFOLLOW,
        0o600,
    )
    with os.fdopen(fd, "w") as fh:
        fh.write(json.dumps(data, indent=2))


def _capabilities_local_path():
    """Local capabilities.json path. PANDASTACK_LOCAL_STATE overrides for tests."""
    override = os.environ.get("PANDASTACK_LOCAL_STATE")
    if override:
        return Path(override)
    return REPO_ROOT / ".pandastack" / "local" / "capabilities.json"


def _runtimes_global_path():
    """Global runtimes.json path under HOME."""
    return Path.home() / ".pandastack" / "runtimes.json"


def build_auth_map(runtimes):
    """Auth status map — presence only, no token values."""
    def _status(cmd):
        return "unknown" if runtimes.get(cmd, False) else "unsupported"
    return {
        "claude": {"status": _status("claude")},
        "codex": {"status": _status("codex")},
        "hermes": {"status": _status("hermes")},
    }


def build_capabilities_map(runtimes, roles, manifest_check, recommendation, now=None):
    """Build the full capability-map JSON dict from live detection state."""
    if now is None:
        now = _get_now()
    skill_counts = manifest_check.get("skill_counts", {})
    return {
        "schema_version": SCHEMA_VERSION,
        "generated_at": now,
        "repo": str(REPO_ROOT),
        "source": "scripts/pandastack doctor",
        "roles": {
            "host": roles["host"],
            "worker": roles["worker"],
            "operator": roles["operator"],
        },
        "runtimes": runtimes,
        "skills": {
            "counts": {
                "core": skill_counts.get("core", 0),
                "ext": skill_counts.get("ext", 0),
                "total": skill_counts.get("total", 0),
            },
            "available": [],
        },
        "auth": build_auth_map(runtimes),
        "limits": {
            "network": "unknown",
            "write_scope": "unknown",
        },
        "next_actions": recommendation.get("next_actions", []),
    }


def build_runtimes_file_map(runtimes, now=None):
    """Build global runtimes.json dict — no secret values."""
    if now is None:
        now = _get_now()
    ai_runtimes = ["claude", "codex", "hermes"]
    result = {}
    for name in ai_runtimes:
        present = runtimes.get(name, False)
        path = shutil.which(name) if present else None
        auth = "unknown" if present else "unsupported"
        result[name] = {"present": present, "path": path, "auth": auth}
    return {
        "schema_version": SCHEMA_VERSION,
        "generated_at": now,
        "runtimes": result,
    }


def _validate_state_file(data):
    """Return (data_or_None, reason). Reject non-object or schema-mismatched files."""
    if not isinstance(data, dict):
        return None, f"expected a JSON object, got {type(data).__name__}"
    version = data.get("schema_version")
    if version != SCHEMA_VERSION:
        return None, (
            f"schema_version {version} != {SCHEMA_VERSION} — "
            "run: scripts/pandastack doctor --write-capabilities"
        )
    return data, None


def read_or_build_capabilities(runtimes, roles, manifest_check, recommendation):
    """Merge capabilities from files, fall back to live detection.

    Priority: local capabilities.json > global runtimes.json overlay > live detection.
    pandastack.toml declares intended defaults for humans and is not merged here.
    Files that are not JSON objects or whose schema_version does not match are
    ignored with a warning. Always returns valid JSON; missing/ignored files
    produce entries in 'warnings'.
    """
    now = _get_now()
    warnings = []
    local_path = _capabilities_local_path()
    global_path = _runtimes_global_path()

    local_data = None
    if local_path.exists():
        try:
            local_data = json.loads(local_path.read_text())
        except Exception as exc:
            warnings.append(f"Failed to parse {local_path}: {exc}")
        else:
            local_data, why = _validate_state_file(local_data)
            if why:
                warnings.append(f"Ignoring {local_path}: {why}")
    else:
        warnings.append(
            f"Local capabilities not found: {local_path} — "
            "run: scripts/pandastack doctor --write-capabilities"
        )

    global_data = None
    if global_path.exists():
        try:
            global_data = json.loads(global_path.read_text())
        except Exception as exc:
            warnings.append(f"Failed to parse {global_path}: {exc}")
        else:
            global_data, why = _validate_state_file(global_data)
            if why:
                warnings.append(f"Ignoring {global_path}: {why}")
    else:
        warnings.append(
            f"Global runtimes not found: {global_path} — "
            "run: scripts/pandastack doctor --write-capabilities"
        )

    if local_data is not None:
        cap = dict(local_data)
    else:
        cap = build_capabilities_map(
            runtimes, roles, manifest_check, recommendation, now=now
        )

    if global_data is not None:
        # global_data["runtimes"] uses {name: {present,path,auth}} schema;
        # cap["runtimes"] uses {cmd: bool}. Convert and propagate auth.
        global_rts = global_data.get("runtimes", {})
        updated_runtimes = dict(cap.get("runtimes", {}))
        updated_auth = {k: dict(v) for k, v in cap.get("auth", {}).items()}
        for name, info in global_rts.items():
            if isinstance(info, dict):
                present = info.get("present", False)
                updated_runtimes[name] = present
                # Keep the auth keyset aligned with the runtimes keyset so a
                # consumer iterating either map sees the same runtimes.
                if name not in updated_auth:
                    updated_auth[name] = {
                        "status": "unknown" if present else "unsupported"
                    }
                if info.get("auth"):
                    updated_auth[name]["status"] = info["auth"]
        cap = dict(cap)
        cap["runtimes"] = updated_runtimes
        cap["auth"] = updated_auth
        # Re-derive worker.codex_backend_ready/status from the merged runtime
        # map so the document cannot say codex absent yet codex_backend_ready.
        roles_out = cap.get("roles")
        worker = roles_out.get("worker") if isinstance(roles_out, dict) else None
        if isinstance(worker, dict) and "codex" in updated_runtimes:
            worker = dict(worker)
            worker["codex_backend_ready"] = updated_runtimes["codex"]
            if "status" in worker:
                worker["status"] = _worker_status(
                    worker.get("agent_worker_present", False),
                    updated_runtimes["codex"],
                )
            roles_out = dict(roles_out)
            roles_out["worker"] = worker
            cap["roles"] = roles_out

    if warnings:
        cap = dict(cap)
        cap["warnings"] = warnings

    return cap, warnings


# ---------------------------------------------------------------------------
# Recommendation engine
# ---------------------------------------------------------------------------

def derive_recommendation(runtimes):
    """Return recommendation dict with profile, operator_notes, next_actions."""
    claude = runtimes.get("claude", False)
    codex = runtimes.get("codex", False)
    pdctx = runtimes.get("pdctx", False)

    if claude and codex:
        profile = "cross-runtime"
    elif claude:
        profile = "claude-only"
    elif codex:
        profile = "codex-only"
    else:
        profile = "bootstrap-only"

    operator_notes = []
    if pdctx:
        operator_notes.append(
            "pdctx detected — Hermes available as scheduler/operator"
        )

    next_actions = []

    agents_md = Path.home() / ".agents" / "AGENTS.md"
    if not agents_md.exists():
        next_actions.append({
            "priority": 0,
            "action": "Create substrate ~/.agents/AGENTS.md (required)",
            "commands": [
                f"mkdir -p {Path.home()}/.agents",
                f"# create {Path.home()}/.agents/AGENTS.md (see README § Substrate)",
            ],
        })

    if profile == "bootstrap-only":
        next_actions.append({
            "priority": 1,
            "action": "Install a host runtime",
            "commands": [
                "# Claude Code (recommended):",
                f"/plugin marketplace add {REPO_ROOT}",
                "/plugin install pandastack@pandastack",
                "/reload-plugins",
                "# OR Codex CLI:",
                "mkdir -p $HOME/.codex/skills",
                f"ln -sfn {REPO_ROOT}/plugins/pandastack/skills"
                " $HOME/.codex/skills/pandastack",
            ],
        })
    elif profile == "claude-only":
        next_actions.append({
            "priority": 1,
            "action": "Install Codex CLI for worker backend (optional)",
            "commands": ["npm install -g @openai/codex"],
        })
    elif profile == "codex-only":
        next_actions.append({
            "priority": 1,
            "action": "Install Claude Code for full host support (optional)",
            "commands": [
                "# Install Claude Code from: https://claude.ai/code",
                f"/plugin marketplace add {REPO_ROOT}",
                "/plugin install pandastack@pandastack",
                "/reload-plugins",
            ],
        })

    return {"profile": profile, "operator_notes": operator_notes,
            "next_actions": next_actions}


# ---------------------------------------------------------------------------
# Subcommand: doctor
# ---------------------------------------------------------------------------

def run_doctor(args):
    manifest_ok, manifest_err, manifest_data = load_manifest()
    if not manifest_ok:
        print(f"ERROR: {manifest_err}", file=sys.stderr)
        sys.exit(1)

    substrate_checks = check_substrate()
    manifest_check = check_manifest_skills(manifest_data)
    runtimes = detect_runtimes()
    roles = derive_roles(runtimes)
    recommendation = derive_recommendation(runtimes)

    local_path = _capabilities_local_path()
    global_path = _runtimes_global_path()
    now = _get_now()

    # --write-capabilities: build from live detection and write both files
    if getattr(args, "write_capabilities", False):
        cap = build_capabilities_map(
            runtimes, roles, manifest_check, recommendation, now=now
        )
        runtimes_map = build_runtimes_file_map(runtimes, now=now)

        try:
            _safe_write_json(local_path, cap)
            _safe_write_json(global_path, runtimes_map)
        except OSError as exc:
            print(f"ERROR: {exc}", file=sys.stderr)
            sys.exit(1)

        if getattr(args, "json", False):
            print(json.dumps(cap, indent=2))
        else:
            print(f"Wrote: {local_path}")
            print(f"Wrote: {global_path}")
        return

    # --capabilities-json: read from files with live detection fallback
    if getattr(args, "capabilities_json", False):
        cap, _ = read_or_build_capabilities(
            runtimes, roles, manifest_check, recommendation
        )
        print(json.dumps(cap, indent=2))
        return

    output = {
        "schema_version": SCHEMA_VERSION,
        "repo": str(REPO_ROOT),
        "host": getattr(args, "host", "auto") or "auto",
        "roles": roles,
        "checks": {
            "substrate": substrate_checks,
            "manifest": manifest_check,
            "runtimes": runtimes,
        },
        "recommendation": recommendation,
        "next_actions": recommendation["next_actions"],
        "capabilities_paths": {
            "local_state": str(local_path),
            "global_runtimes": str(global_path),
            "local_state_exists": local_path.exists(),
            "global_runtimes_exists": global_path.exists(),
        },
    }

    if args.json:
        print(json.dumps(output, indent=2))
        return

    _print_doctor_text(output)


def _print_doctor_text(out):
    print()
    print("pandastack doctor")
    print("=================")
    print(f"Repo: {out['repo']}")
    print()

    print("Substrate")
    print("---------")
    for c in out["checks"]["substrate"]:
        sym = "+" if c["ok"] else "!"
        print(f"  [{sym}] {c['name']}: {c['message']}")
        if c.get("fix"):
            print(f"        Fix: {c['fix']}")
    print()

    mc = out["checks"]["manifest"]
    sc = mc["skill_counts"]
    print("Manifest")
    print("--------")
    sym = "+" if mc["ok"] else "!"
    print(f"  [{sym}] manifest.toml: {'ok' if mc['ok'] else 'drift detected'}")
    print(f"        Core: {sc['core']}  Ext: {sc['ext']}  Total: {sc['total']}")
    if mc["drift"]["missing_on_disk"]:
        print(f"        Missing on disk: {', '.join(mc['drift']['missing_on_disk'])}")
    if mc["drift"]["missing_in_manifest"]:
        print(f"        Missing in manifest: "
              f"{', '.join(mc['drift']['missing_in_manifest'])}")
    print()

    roles = out["roles"]

    print("Host runtime")
    print("------------")
    for name, info in roles["host"].items():
        if name == "hermes":
            sym = "+" if info["ready"] else "~"
            print(f"  [{sym}] {name}: {info['status']}")
            print(f"        {info['note']}")
        else:
            sym = "+" if info["ready"] else "x"
            print(f"  [{sym}] {name}: {'ready' if info['ready'] else 'not found'}")
            if info.get("install_hint") and not info["ready"]:
                for line in info["install_hint"].splitlines():
                    print(f"        {line}")
    print()

    print("Worker runtime")
    print("--------------")
    w = roles["worker"]
    sym = "+" if w["agent_worker_present"] else "x"
    print(f"  [{sym}] agent-worker: "
          f"{'present' if w['agent_worker_present'] else 'missing'}")
    sym = "+" if w["codex_backend_ready"] else "~"
    print(f"  [{sym}] codex backend: "
          f"{'ready' if w['codex_backend_ready'] else 'not found'}")
    print("  [+] test backend: always available")
    for warn in w.get("warnings", []):
        print(f"      [!] {warn}")
    print()

    print("Operator runtime")
    print("----------------")
    op = roles["operator"]
    print("  [+] shell/manual: always available")
    sym = "+" if op["launchd"] else "~"
    print(f"  [{sym}] launchd: "
          f"{'detected (Darwin)' if op['launchd'] else 'not available'}")
    sym = "+" if op["hermes_cron"] else "~"
    print(f"  [{sym}] Hermes cron: "
          f"{'pdctx present' if op['hermes_cron'] else 'informational (pdctx not found)'}")
    print()

    rec = out["recommendation"]
    print("Recommendation")
    print("--------------")
    print(f"  Profile: {rec['profile']}")
    for note in rec.get("operator_notes", []):
        print(f"  Note: {note}")
    for action in rec.get("next_actions", []):
        print(f"\n  [{action['priority']}] {action['action']}")
        for cmd in action.get("commands", []):
            print(f"        {cmd}")
    print()


# ---------------------------------------------------------------------------
# Subcommand: init
# ---------------------------------------------------------------------------

def run_init(args):
    host = getattr(args, "host", None) or "claude"
    dry_run = getattr(args, "dry_run", False)

    if not dry_run:
        if host in ("claude", "hermes"):
            print(
                f"init --host {host}: mutation not supported in this release.",
                file=sys.stderr,
            )
            print(
                "Re-run with --dry-run to see the commands, then run them manually.",
                file=sys.stderr,
            )
            sys.exit(1)
        elif host == "codex":
            skills_target = REPO_ROOT / "plugins/pandastack/skills"
            codex_skills = Path.home() / ".codex" / "skills"
            link_path = codex_skills / "pandastack"
            if link_path.is_dir() and not link_path.is_symlink():
                print(
                    f"ERROR: {link_path} is a real directory, not a symlink. "
                    "Remove or back it up manually, then re-run.",
                    file=sys.stderr,
                )
                sys.exit(1)
            print(f"Creating Codex symlink: {link_path} -> {skills_target}")
            codex_skills.mkdir(parents=True, exist_ok=True)
            if link_path.is_symlink() or link_path.is_file():
                link_path.unlink()
            link_path.symlink_to(skills_target)
            print("Done. Restart Codex CLI to pick up pandastack skills.")
            return
        else:
            print(f"Unknown host: {host}. Use --host claude|codex|hermes",
                  file=sys.stderr)
            sys.exit(2)

    # Dry run output
    print()
    print(f"pandastack init --host {host} --dry-run")
    print(f"Repo: {REPO_ROOT}")
    print()

    if host == "claude":
        print("Commands to install pandastack in Claude Code:")
        print(f"  /plugin marketplace add {REPO_ROOT}")
        print("  /plugin install pandastack@pandastack")
        print("  /reload-plugins")
        print()
        print("Then run /pandastack:init once inside your project.")
    elif host == "codex":
        skills_target = REPO_ROOT / "plugins/pandastack/skills"
        print("Commands to install pandastack in Codex CLI:")
        print("  mkdir -p $HOME/.codex/skills")
        print(f"  ln -sfn {skills_target} $HOME/.codex/skills/pandastack")
        print()
        print("Restart Codex CLI to pick up skills.")
    elif host == "hermes":
        if not shutil.which("pdctx"):
            print("WARNING: pdctx not found — Hermes support degraded.")
            print("  See docs/HERMES.md for the supported path with pdctx.")
        else:
            print("Hermes operator setup (via pdctx):")
            print("  pdctx use personal:developer")
            print("  # See docs/HERMES.md for full dispatch setup")
        print()
        print("Note: Hermes is supported as scheduler/operator.")
        print("No mutation of ~/.hermes will be performed by this command.")
    else:
        print(f"Unknown host: {host}. Use --host claude|codex|hermes",
              file=sys.stderr)
        sys.exit(2)

    print()


# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------

def main():
    parser = argparse.ArgumentParser(
        prog="pandastack",
        description="pandastack CLI — doctor and init front-door",
    )
    sub = parser.add_subparsers(dest="command")

    doc = sub.add_parser("doctor", help="Detect runtime state and print next actions")
    doc.add_argument("--json", action="store_true", help="Emit JSON")
    doc.add_argument(
        "--host",
        choices=["claude", "codex", "hermes", "auto"],
        default="auto",
        help="Host runtime context (default: auto)",
    )
    doc.add_argument(
        "--capabilities-json",
        dest="capabilities_json",
        action="store_true",
        help="Emit merged capability-map JSON (reads files, falls back to live detection)",
    )
    doc.add_argument(
        "--write-capabilities",
        dest="write_capabilities",
        action="store_true",
        help="Write .pandastack/local/capabilities.json and ~/.pandastack/runtimes.json",
    )

    ini = sub.add_parser("init", help="Print or run host install commands")
    ini.add_argument(
        "--host",
        choices=["claude", "codex", "hermes"],
        default="claude",
        help="Target host (default: claude)",
    )
    ini.add_argument("--dry-run", action="store_true",
                     help="Print commands without running them")

    sub.add_parser("help", help="Show this help message")

    args = parser.parse_args()

    if args.command == "doctor":
        run_doctor(args)
    elif args.command == "init":
        run_init(args)
    elif args.command == "help":
        parser.print_help()
    elif args.command is None:
        parser.print_help()
    else:
        parser.print_help()
        sys.exit(2)


if __name__ == "__main__":
    main()
