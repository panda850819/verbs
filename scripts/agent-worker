#!/usr/bin/env python3
"""agent-worker — repo-local worker protocol adapter.

Protocol boundary:
  agent-worker run \
    --backend codex|test \
    --job-dir <path> \
    --worktree <path> \
    --prompt <path> \
    --out <path>

The flow code owns job selection and policy. This adapter owns backend-specific CLI
flags, output capture, RESULT parsing, changed-file reporting, verification, and logs.
"""
import argparse
import json
import os
import signal
import subprocess
import sys
import tempfile
import time

HERE = os.path.dirname(os.path.abspath(__file__))
sys.path.insert(0, HERE)
import pslib

DEFAULT_REQUEST = {
    "mode": "read-only",
    "network_access": False,
    "timeout_seconds": 1200,
}
MAX_UNTRACKED_PATCH_BYTES = 1024 * 1024


def utc_now():
    return time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime())


def ensure_dirs(job_dir, out_path):
    os.makedirs(job_dir, exist_ok=True)
    os.makedirs(os.path.join(job_dir, "logs"), exist_ok=True)
    os.makedirs(os.path.join(job_dir, "output"), exist_ok=True)
    os.makedirs(os.path.dirname(os.path.abspath(out_path)), exist_ok=True)


def load_request(job_dir):
    req = dict(DEFAULT_REQUEST)
    path = os.path.join(job_dir, "request.json")
    if os.path.exists(path):
        with open(path, encoding="utf-8") as f:
            data = json.load(f)
        if not isinstance(data, dict):
            raise SystemExit("request.json must be an object")
        req.update(data)
    allowed = {"mode", "network_access", "timeout_seconds", "allow_host_verify"}
    extra = sorted(set(req) - allowed)
    if extra:
        raise SystemExit("request.json has unsupported keys: " + ", ".join(extra))
    for name in ("network_access", "allow_host_verify"):
        if name in req and not isinstance(req[name], bool):
            raise SystemExit(f"request.{name} must be a boolean")
    mode = req.get("mode")
    if mode not in {"read-only", "workspace-write"}:
        raise SystemExit("request.mode must be read-only or workspace-write")
    if mode == "workspace-write" and req.get("network_access") is not False:
        raise SystemExit("workspace-write jobs require network_access=false")
    try:
        req["timeout_seconds"] = int(req.get("timeout_seconds") or DEFAULT_REQUEST["timeout_seconds"])
    except (TypeError, ValueError):
        req["timeout_seconds"] = DEFAULT_REQUEST["timeout_seconds"]
    if req["timeout_seconds"] <= 0:
        req["timeout_seconds"] = DEFAULT_REQUEST["timeout_seconds"]
    return req


def append_log(job_dir, event, **fields):
    path = os.path.join(job_dir, "logs", "stdout.jsonl")
    rec = {"ts": utc_now(), "event": event}
    rec.update(fields)
    with open(path, "a", encoding="utf-8") as f:
        f.write(json.dumps(rec, ensure_ascii=False, sort_keys=True) + "\n")


def tail(s, n=4000):
    s = s or ""
    return s[-n:]


def read_text(path):
    with open(path, encoding="utf-8") as f:
        return f.read()


def worker_env():
    keep_exact = {
        "PATH", "HOME", "USER", "LOGNAME", "SHELL", "TMPDIR", "TEMP", "TMP",
        "LANG", "LC_ALL", "LC_CTYPE", "TERM", "COLORTERM", "NO_COLOR",
        "SSL_CERT_FILE", "SSL_CERT_DIR",
    }
    keep_prefixes = ("LC_",)
    return {
        key: value for key, value in os.environ.items()
        if key in keep_exact or any(key.startswith(prefix) for prefix in keep_prefixes)
    }


def write_json(path, data):
    parent = os.path.dirname(path) or "."
    os.makedirs(parent, exist_ok=True)
    fd, tmp = tempfile.mkstemp(prefix=".tmp-", suffix=".json", dir=parent)
    try:
        with os.fdopen(fd, "w", encoding="utf-8") as f:
            json.dump(data, f, ensure_ascii=False, indent=2, sort_keys=True)
            f.write("\n")
        os.replace(tmp, path)
    except Exception:
        try:
            os.unlink(tmp)
        except OSError:
            pass
        raise


def git_env():
    env = os.environ.copy()
    env.update({
        "GIT_CONFIG_NOSYSTEM": "1",
        "GIT_CONFIG_GLOBAL": os.devnull,
        "GIT_CONFIG_SYSTEM": os.devnull,
    })
    return env


def git_cmd(worktree, git_dir, args):
    if git_dir:
        cmd = ["git", "--git-dir", git_dir, "--work-tree", worktree]
    else:
        cmd = ["git", "-C", worktree]
    cmd.extend(["-c", "core.fsmonitor=false", "-c", "core.hooksPath=/dev/null"])
    cmd.extend(args)
    return subprocess.run(cmd, capture_output=True, text=True, env=git_env())


def git_status_lines(worktree, git_dir=None):
    cp = git_cmd(worktree, git_dir, ["status", "--porcelain", "--untracked-files=all"])
    if cp.returncode != 0:
        return []
    return cp.stdout.splitlines()


def git_changed_files(worktree, git_dir=None):
    files = []
    for line in git_status_lines(worktree, git_dir):
        if len(line) >= 4:
            files.append(line[3:])
    return files


def trusted_git_dir(worktree):
    cp = subprocess.run(["git", "-C", worktree, "rev-parse", "--git-dir"],
                        capture_output=True, text=True)
    if cp.returncode != 0:
        return None
    git_dir = cp.stdout.strip()
    if not os.path.isabs(git_dir):
        git_dir = os.path.join(worktree, git_dir)
    return os.path.realpath(git_dir)


def path_inside(parent, child):
    parent = os.path.realpath(parent)
    child = os.path.realpath(child)
    try:
        return os.path.commonpath([parent, child]) == parent
    except ValueError:
        return False


def validate_job_layout(job_dir, worktree, request):
    if request.get("mode") == "workspace-write" and path_inside(worktree, job_dir):
        raise SystemExit("workspace-write job-dir must be outside worktree")


def validate_output_path(job_dir, worktree, out_path):
    job_output = os.path.join(job_dir, "output")
    if not path_inside(job_output, out_path):
        raise SystemExit("--out must be under job-dir/output")
    if path_inside(worktree, out_path):
        raise SystemExit("--out must not be inside worktree")


def artifact_paths(job_dir):
    return {
        "job_dir": job_dir,
        "result_json": os.path.join(job_dir, "output", "result.json"),
        "diff_patch": os.path.join(job_dir, "output", "diff.patch"),
        "stdout_jsonl": os.path.join(job_dir, "logs", "stdout.jsonl"),
    }


def _append_untracked_patch(f, worktree, rel):
    raw_path = os.path.abspath(os.path.join(worktree, rel))
    if not path_inside(worktree, raw_path):
        return
    try:
        st = os.lstat(raw_path)
    except OSError:
        return
    if os.path.islink(raw_path):
        return
    if st.st_size > MAX_UNTRACKED_PATCH_BYTES:
        f.write(f"# skipped oversized untracked file: {rel}\n")
        return
    path = os.path.realpath(raw_path)
    if not path_inside(worktree, path) or not os.path.isfile(path):
        return
    try:
        data = open(path, "rb").read()
    except OSError:
        return
    safe = rel.replace("\\", "/")
    f.write(f"diff --git a/{safe} b/{safe}\n")
    f.write("new file mode 100644\n")
    if b"\0" in data[:8000]:
        f.write(f"Binary files /dev/null and b/{safe} differ\n")
        return
    text = data.decode("utf-8", "replace")
    lines = text.splitlines()
    f.write("--- /dev/null\n")
    f.write(f"+++ b/{safe}\n")
    f.write(f"@@ -0,0 +1,{len(lines)} @@\n")
    for line in lines:
        f.write("+" + line + "\n")


def write_diff_patch(job_dir, worktree, git_dir=None, include_untracked=True):
    path = os.path.join(job_dir, "output", "diff.patch")
    os.makedirs(os.path.dirname(path), exist_ok=True)
    cp = git_cmd(worktree, git_dir,
                 ["diff", "HEAD", "--binary", "--no-ext-diff", "--no-textconv"])
    untracked = None
    if include_untracked:
        untracked = git_cmd(worktree, git_dir,
                            ["ls-files", "--others", "--exclude-standard", "-z"])
    with open(path, "w", encoding="utf-8") as f:
        if cp.returncode == 0:
            f.write(cp.stdout)
            if cp.stdout and not cp.stdout.endswith("\n"):
                f.write("\n")
        if untracked is not None and untracked.returncode == 0:
            for rel in [x for x in untracked.stdout.split("\0") if x]:
                _append_untracked_patch(f, worktree, rel)
    return path


def finalize_artifacts(result, job_dir, worktree, git_dir, request):
    result["changed_files"] = git_changed_files(worktree, git_dir)
    include_untracked = request.get("mode") == "workspace-write"
    write_diff_patch(job_dir, worktree, git_dir, include_untracked=include_untracked)
    result["artifacts"] = artifact_paths(job_dir)
    return result


def run_verify(job_dir, worktree, request):
    verify = os.path.join(job_dir, "verify.sh")
    if not os.path.exists(verify):
        return {"ran": False, "ok": None, "command": None}
    if not request.get("allow_host_verify"):
        return {"ran": False, "ok": None, "command": verify,
                "skipped": "host verification not enabled"}
    if os.path.islink(verify) or path_inside(worktree, verify):
        return {"ran": True, "ok": False, "command": verify,
                "error": "verify.sh must be a non-symlink outside worktree"}
    try:
        p = subprocess.Popen(["bash", verify], cwd=worktree, stdout=subprocess.PIPE,
                             stderr=subprocess.PIPE, text=True, start_new_session=True,
                             env=worker_env())
        try:
            stdout, stderr = p.communicate(timeout=request["timeout_seconds"])
            timed_out = False
        except subprocess.TimeoutExpired:
            timed_out = True
            try:
                os.killpg(p.pid, signal.SIGKILL)
            except ProcessLookupError:
                pass
            stdout, stderr = p.communicate()
        if timed_out:
            return {
                "ran": True,
                "ok": False,
                "command": verify,
                "returncode": None,
                "timed_out": True,
                "stdout_tail": tail(stdout),
                "stderr_tail": tail(stderr),
            }
        return {
            "ran": True,
            "ok": p.returncode == 0,
            "command": verify,
            "returncode": p.returncode,
            "stdout_tail": tail(stdout),
            "stderr_tail": tail(stderr),
        }
    except Exception as e:
        return {"ran": True, "ok": False, "command": verify, "error": str(e)[:160]}


def codex_command(request, worktree, raw_out, prompt):
    """Build the backend-specific Codex invocation.

    Kept as a named function so tests can prove sandbox flags live in the adapter,
    not in flow code.
    """
    mode = request.get("mode") or DEFAULT_REQUEST["mode"]
    cmd = ["codex", "exec", "-s", mode]
    if mode == "workspace-write" and request.get("network_access") is False:
        cmd.extend(["-c", "sandbox_workspace_write.network_access=false"])
    cmd.extend(["-C", worktree, "--skip-git-repo-check", "-o", raw_out, prompt])
    return cmd


def parse_worker_output(output, returncode):
    verdict, summary = pslib.parse_result(output, returncode)
    return verdict, summary


def base_result(backend, request, status, summary, returncode=None, logs=None,
                changed_files=None, verification=None, artifacts=None):
    return {
        "schema_version": 1,
        "backend": backend,
        "status": status,
        "ok": status == "PASS",
        "summary": summary,
        "returncode": returncode,
        "changed_files": changed_files or [],
        "verification": verification or {"ran": False, "ok": None, "command": None},
        "logs": logs or {},
        "artifacts": artifacts or {},
        "request": {
            "mode": request.get("mode"),
            "network_access": request.get("network_access"),
            "timeout_seconds": request.get("timeout_seconds"),
            "allow_host_verify": bool(request.get("allow_host_verify")),
        },
    }


def maybe_apply_verification(result, verification):
    result["verification"] = verification
    if verification.get("ran") and verification.get("ok") is False and result["status"] == "PASS":
        result["status"] = "FAIL"
        result["ok"] = False
        result["summary"] = "verification failed"
    return result


def run_codex(job_dir, worktree, prompt_path, request):
    prompt = read_text(prompt_path)
    git_dir = trusted_git_dir(worktree)
    fd, raw_out = tempfile.mkstemp(prefix="agent-worker-codex-", suffix=".txt",
                                   dir=os.path.join(job_dir, "output"))
    os.close(fd)
    cmd = codex_command(request, worktree, raw_out, prompt)
    append_log(job_dir, "start", backend="codex", mode=request.get("mode"), worktree=worktree)
    append_log(job_dir, "command", argv=cmd[:-1] + ["<prompt>"])
    try:
        p = subprocess.Popen(cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE,
                             text=True, start_new_session=True, env=worker_env())
        try:
            stdout, stderr = p.communicate(timeout=request["timeout_seconds"])
            timed_out = False
        except subprocess.TimeoutExpired:
            timed_out = True
            try:
                os.killpg(p.pid, signal.SIGKILL)
            except ProcessLookupError:
                pass
            stdout, stderr = p.communicate()
        if timed_out:
            logs = {
                "stdout_tail": tail(stdout),
                "stderr_tail": tail(stderr),
                "raw_output_path": raw_out,
                "stdout_jsonl": os.path.join(job_dir, "logs", "stdout.jsonl"),
            }
            result = base_result("codex", request, "ERROR", "worker timed out",
                                 returncode=None, logs=logs,
                                 changed_files=git_changed_files(worktree, git_dir))
        else:
            output = read_text(raw_out) if os.path.exists(raw_out) else ""
            status, summary = parse_worker_output(output, p.returncode)
            logs = {
                "stdout_tail": tail(stdout),
                "stderr_tail": tail(stderr),
                "raw_output_tail": tail(output),
                "raw_output_path": raw_out,
                "stdout_jsonl": os.path.join(job_dir, "logs", "stdout.jsonl"),
            }
            result = base_result("codex", request, status, summary, p.returncode,
                                 logs=logs, changed_files=git_changed_files(worktree, git_dir))
    except Exception as e:
        result = base_result("codex", request, "ERROR", str(e)[:160],
                             returncode=None, changed_files=git_changed_files(worktree, git_dir))
    verification = run_verify(job_dir, worktree, request)
    result = maybe_apply_verification(result, verification)
    finalize_artifacts(result, job_dir, worktree, git_dir, request)
    append_log(job_dir, "result", status=result["status"], summary=result["summary"])
    return result


def load_test_options(job_dir):
    path = os.path.join(job_dir, "test.json")
    if not os.path.exists(path):
        return {}
    with open(path, encoding="utf-8") as f:
        data = json.load(f)
    if not isinstance(data, dict):
        raise SystemExit("test.json must be an object")
    return data


def run_test_backend(job_dir, worktree, prompt_path, request):
    # Deterministic backend for protocol/drive tests. It never calls external CLIs.
    prompt = read_text(prompt_path)
    opts = load_test_options(job_dir)
    git_dir = trusted_git_dir(worktree)
    append_log(job_dir, "start", backend="test", mode=request.get("mode"), worktree=worktree)
    write_file = opts.get("write_file")
    if write_file:
        if request.get("mode") != "workspace-write":
            return base_result("test", request, "ERROR",
                               "write_file requires workspace-write mode",
                               changed_files=git_changed_files(worktree, git_dir),
                               artifacts=artifact_paths(job_dir))
        root = os.path.realpath(worktree)
        target = os.path.realpath(os.path.join(worktree, write_file))
        if os.path.commonpath([root, target]) != root:
            write_diff_patch(job_dir, worktree, git_dir)
            return base_result("test", request, "ERROR", "write_file escapes worktree",
                               changed_files=git_changed_files(worktree, git_dir),
                               artifacts=artifact_paths(job_dir))
        os.makedirs(os.path.dirname(target), exist_ok=True)
        with open(target, "w", encoding="utf-8") as f:
            f.write(opts.get("write_text", "stub build artifact\n"))
    output = opts.get("result_output") or "RESULT: {} — {}".format(
        opts.get("test_status", "PASS"), opts.get("test_summary", "stubbed"))
    status, summary = parse_worker_output(output, int(opts.get("returncode") or 0))
    result = base_result("test", request, status, summary, int(opts.get("returncode") or 0),
                         logs={
                             "raw_output_tail": tail(output),
                             "prompt_tail": tail(prompt),
                             "stdout_jsonl": os.path.join(job_dir, "logs", "stdout.jsonl"),
                         },
                         changed_files=git_changed_files(worktree, git_dir))
    verification = run_verify(job_dir, worktree, request)
    result = maybe_apply_verification(result, verification)
    finalize_artifacts(result, job_dir, worktree, git_dir, request)
    append_log(job_dir, "result", status=result["status"], summary=result["summary"])
    return result


def run(args):
    job_dir = os.path.abspath(args.job_dir)
    worktree = os.path.abspath(args.worktree)
    prompt_path = os.path.abspath(args.prompt)
    out_path = os.path.abspath(args.out)
    if not os.path.isdir(worktree):
        raise SystemExit("worktree does not exist: " + worktree)
    if not os.path.isfile(prompt_path):
        raise SystemExit("prompt does not exist: " + prompt_path)
    request = load_request(job_dir)
    validate_job_layout(job_dir, worktree, request)
    validate_output_path(job_dir, worktree, out_path)
    ensure_dirs(job_dir, out_path)
    if args.backend == "codex":
        result = run_codex(job_dir, worktree, prompt_path, request)
    elif args.backend == "test":
        result = run_test_backend(job_dir, worktree, prompt_path, request)
    else:
        raise SystemExit("unsupported backend: " + args.backend)
    write_json(out_path, result)
    default_result = os.path.join(job_dir, "output", "result.json")
    if os.path.abspath(default_result) != out_path:
        write_json(default_result, result)
    return 0


def main(argv=None):
    ap = argparse.ArgumentParser(prog="agent-worker")
    sub = ap.add_subparsers(dest="cmd", required=True)
    runp = sub.add_parser("run")
    runp.add_argument("--backend", required=True)
    runp.add_argument("--job-dir", required=True)
    runp.add_argument("--worktree", required=True)
    runp.add_argument("--prompt", required=True)
    runp.add_argument("--out", required=True)
    args = ap.parse_args(argv)
    if args.cmd == "run":
        return run(args)
    return 2


if __name__ == "__main__":
    sys.exit(main())
